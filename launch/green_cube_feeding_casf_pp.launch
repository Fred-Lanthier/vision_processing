<?xml version="1.0"?>
<!-- PICK-AND-PLACE pipeline (Stages B-C wired; D/E = obstacle stage).
     `_pp` copy spirit of green_cube_feeding_casf.launch, reusing the SAME system
     for the pick-and-place policy. The feeding launch is left untouched.

     Data path wired here:
       static cam -> sam3_sam2_node_pp (red cube + brown box) -> 2 masks
       -> 2x point_cloud_projector (target_cube / target_box)
       -> condition_pcd_pickplace (gripper + cube + box, world frame)
       -> casf_generative_node_PC_pp (controlled_link:=panda_TCP, pickplace ckpt)
       -> /planner/nominal_trajectory  (+ RViz viz)

     execute:=true also runs trajectory_executor -> CBF velocity safety shield
     -> joint_group_velocity_controller. The PP obstacle stage uses a static
     cylinder cloud, leaving the feeding launch and shared perception code alone. -->
<launch>
  <arg name="gui" default="true"/>
  <arg name="launch_sam3_server" default="true"/>
  <arg name="launch_rviz" default="false"/>
  <arg name="execute" default="true"/>
  <arg name="venv_python" default="/home/flanthier/Github/src/vision_processing/venv_sam3/bin/python3"/>
  <arg name="pytorch_cuda_alloc_conf" default="expandable_segments:True"/>

  <arg name="cube_prompt" default="red cube"/>
  <arg name="box_prompt"  default="white box"/>
  <!-- Cube conditioning source. false = SAM/depth cloud; true = analytic cloud
       at the ground-truth Gazebo pose ("perfect SAM": exact pose/segmentation,
       camera-visible faces only by default, see gt_cube_cloud_node ~visible_only).
       The SAM pipeline keeps running either way; only the conditioning node's
       cube input switches. -->
  <arg name="use_gt_cube" default="false"/>
  <arg name="pickplace_model_name" default="best_fm_model_pickplace_10D_1024_rdn.ckpt"/>
  <arg name="condition_num_points" default="1024"/>
  <arg name="planner_rate_hz" default="3"/>
  <!-- Via-point detour router (A/B toggle). true = insert a deterministic
       routing layer between the FM planner and the executor: when the FM
       trajectory's TCP path is blocked by the obstacle cloud, it enumerates
       around-left / around-right / over-top from the cloud's extents,
       commits to the best reachable one and splices the blocked segment
       through it (task-space interp + fast_ik). Unblocked trajectories pass
       through byte-identical, and false removes the node entirely (planner
       publishes /planner/nominal_trajectory directly, exactly the legacy
       pipeline). The CBF stays the pure 100 Hz safety shield either way;
       this layer owns the ONE decision neither the obstacle-blind FM nor a
       reactive filter can make: the homotopy class around a big obstacle. -->
  <arg name="enable_viapoint_detour" default="true"/>
  <arg name="control_rate_hz" default="100.0"/>
  <arg name="max_joint_velocity" default="0.7"/>
  <arg name="single_shot" default="false"/>

  <!-- Static PP CBF obstacle. Coordinates are in the robot/table frame; Gazebo
       spawn adds the table-top z offset internally. -->
  <arg name="obstacle_enabled" default="true"/>
  <arg name="obstacle_shape" default="prism"/>
  <arg name="obstacle_x" default="0.535"/>
  <arg name="obstacle_y" default="-0.190"/>
  <!-- Local +Y faces the red cube by default. This matters for the crescent. -->
  <arg name="obstacle_yaw" default="-0.160"/>
  <arg name="obstacle_radius" default="0.040"/>
  <arg name="obstacle_height" default="0.36"/>
  <arg name="obstacle_prism_size_x" default="0.200"/>
  <arg name="obstacle_prism_size_y" default="0.060"/>
  <arg name="obstacle_prism_height" default="0.36"/>
  <!-- Gazebo world z for the obstacle center. Table top is z=0.75, so the
       default keeps the selected obstacle resting on the table. -->
  <arg name="obstacle_gazebo_z"
       default="$(eval 0.75 + 0.5 * (float(arg('obstacle_prism_height')) if arg('obstacle_shape') == 'prism' else float(arg('obstacle_height'))))"/>
  <arg name="obstacle_crescent_outer_radius" default="0.055"/>
  <arg name="obstacle_crescent_inner_radius" default="0.055"/>
  <arg name="obstacle_crescent_bite_offset" default="0.030"/>
  <arg name="obstacle_cloud_points" default="1000"/>
  <arg name="obstacle_cloud_topic" default="/perception/cleaned_obstacles"/>
  <arg name="obstacle_cloud_extra_topic" default="/perception/persistent_obstacles"/>
  <!-- Camera-independent moving obstacle, same idea as green_cube_feeding_casf:
       it is added to the published obstacle cloud without leaving a stale trail. -->
  <arg name="moving_sphere_enabled" default="true"/>
  <arg name="moving_sphere_initial_x" default="0.10"/>
  <arg name="moving_sphere_initial_y" default="-0.190"/>
  <arg name="moving_sphere_initial_z" default="0.55"/>
  <arg name="moving_sphere_velocity_x" default="0.0"/>
  <arg name="moving_sphere_velocity_y" default="0.0"/>
  <arg name="moving_sphere_velocity_z" default="0.0"/>
  <arg name="moving_sphere_radius" default="0.08"/>
  <arg name="moving_sphere_num_points" default="1000"/>
  <!-- Mirror the virtual sphere into Gazebo as a visual-only (collision-free)
       model so it is visible there too, not just in RViz. -->
  <arg name="moving_sphere_gazebo_mirror" default="true"/>

  <!-- Online CBF tuning, matching the tested feeding values where applicable. -->
  <arg name="enable_cbf" default="true"/>
  <arg name="cbf_node_type" default="cbf_safety_node_Bernstein_multicbf.py"/>
  <arg name="cbf_graph_points" default="64"/>
  <arg name="cbf_preprocess_max_points" default="4096"/>
  <arg name="cbf_candidate_filter" default="sdf"/>
  <arg name="cbf_selection_metric" default="sdf"/>
  <arg name="cbf_cluster_mode" default="topk"/>
  <!-- Critical-point selection path (A/B toggle; legacy = the old code).
       graphed = ONE fixed-width CUDA-graph replay does FK + whole-body SDF +
       self-filter + top-k. It replaces three dynamic-shape passes over the
       cloud (cdist prefilter -> chunked eager SDF -> boolean keep_mask ->
       cat -> topk), whose mask-index forced a D2H sync in the preprocess
       thread. Bit-exact vs the eager path over random q / cloud sizes.
       Live A/B in this scene (/pipeline/timing/critical_point_selection,
       n / mean / p50 / p95 / max in ms):
         legacy  562  40.52  37.92  73.43  100.78
         graphed 737   1.05   0.52   3.59   16.60
       i.e. p50 73x, p95 20x. The isolated benchmark only showed 4x (3.8 ->
       1.0 ms): most of the legacy cost is not arithmetic but the mask-index
       D2H sync waiting behind SAM2/FM work in the shared GPU queue, which
       only exists in the full system. Killing the sync is the real win.
       The dropped prefilter was pure waste here anyway: the PP cloud (2000)
       never reached cbf_sdf_prefilter_max_points (4096), so its cdist was
       computed and discarded every cycle.
       Works with cbf_barrier_value_mode hard AND soft. (It briefly required
       hard: the graph emits a fixed k rows padded with dummies, so the count
       soft mode needs for its alpha*log(N) de-bias was wrong. The graph now
       emits the real count and an async D2H lands it in pinned memory, read
       at adoption, with no sync. If the selection silently reverts to legacy
       timings, check the startup log: an unsupported config, e.g.
       cbf_selection_metric != sdf, falls back with a warning.) -->
  <arg name="cbf_selection_mode" default="graphed"/>
  <!-- Fixed graph width. Must cover the whole cloud, else the cdist broad
       phase re-engages to choose which points survive (truncating a cloud
       would drop real obstacles). Observed: PP 2000 pts (1000 obstacle +
       1000 sphere), feeding 2573, so 4096 covers both with headroom.
       Cost tracks the padded width, not the real cloud: 2048 -> 0.68 ms,
       4096 -> 0.90 ms, 10000 -> 1.72 ms; oversizing just buys dummy SDF
       evaluations. Raise it only if the cloud actually grows. -->
  <arg name="cbf_sdf_graph_points" default="4096"/>
  <!-- Critical-point selection rate. Was the node default (30 Hz), now the
       control rate: the selection IS what the barrier sees, so refreshing it
       at 100 Hz stops the QP filtering against a cloud chosen up to 33 ms
       ago. ONLY affordable on the graphed path: legacy's p50 of 37.92 ms
       could not even hold the old 30 Hz tick (33 ms budget), so it was
       already being dropped by the skip-if-busy gate in preprocess_obstacles
       (the selection was effectively running at ~26 Hz, not the 30 it claimed).
       Graphed p50 0.52 ms is ~5% of a 10 ms tick; the rare 16.6 ms outlier
       just drops a tick through that same gate. Set this back to 30.0 when
       running cbf_selection_mode:=legacy for the A/B arm, or the legacy arm
       will spend the whole run in skip-if-busy. -->
  <arg name="cbf_preprocess_rate_hz" default="100.0"/>
  <arg name="cbf_sdf_candidate_max_dist" default="0.35"/>
  <arg name="cbf_sdf_prune_chunk_size" default="2048"/>
  <arg name="cbf_sdf_self_filter_margin" default="-0.05"/>
  <arg name="cbf_sdf_prefilter_radius" default="0.4"/>
  <arg name="cbf_sdf_prefilter_max_points" default="4096"/>
  <!-- PP needs the obstacle shield on the whole gripper/arm body. fast_tangent
       collapses the analytical per-link barriers to only the current min link;
       multi_graphed keeps the CUDA-graph speed while projecting through the
       selected per-link half-spaces. There are 9 protected PP links below. -->
  <arg name="cbf_solver_mode" default="multi_graphed"/>
  <arg name="cbf_active_constraints" default="9"/>
  <!-- Run the 100 Hz control loop on a high-priority CUDA stream, separate
       from the preprocess stream (cbf_preprocess_rate_hz), so the command D2H readback stops
       waiting behind the whole-body SDF batches under SAM2/FM contention
       (runPP100: cbf_total p50 ~16 ms, loop at ~33 Hz effective). -->
  <arg name="cbf_separate_streams" default="true"/>
  <!-- Capture the ENTIRE per-cycle correction+command pipeline in the CUDA
       graph (escape/clearance compose, solve, dynamic hdot, repair,
       integration, command fill): one replay instead of ~90 eager ops. The
       eager loop was dispatch/GIL-bound under SAM2+FM contention (~80 us per
       op, cbf_correction p50 16 ms with the GPU idle at readback). -->
  <arg name="cbf_graphed_control_step" default="true"/>
  <!-- POCS sweeps over the active per-link half-space constraints. -->
  <arg name="cbf_constraint_sweeps" default="6"/>
  <!-- Inner QP solver over the active half-spaces. pocs = legacy cyclic
       projections: converges to A feasible dq, which over-corrects when
       several rows are active at once (the excess of an early projection is
       never given back) and depends on row order. dykstra = Dykstra's
       corrected projections (= Hildreth's dual method for half-spaces):
       one correction-memory vector per row, converges to the EXACT
       min-W-norm projection of the nominal onto the intersection, i.e. the
       true QP optimum. Identical output when at most 1 constraint is active;
       smaller, order-independent corrections in multi-constraint episodes
       (wall graze, pocket, food+robot). ~2 extra vector ops per row-step
       inside the CUDA graph (sub-ms). Refs in the node comment
       (Dykstra 1983; Boyle & Dykstra 1986; Hildreth 1957). -->
  <arg name="cbf_qp_algorithm" default="dykstra"/>
  <!-- Cross-cycle Dykstra warm start: carry the dual multipliers per link
       identity across cycles (offline prototype: solver_study.py - the
       ill-conditioned tail converges in ~2-3 cycles instead of plateauing).
       OFF until validated in sim (A/B on the wall-graze scenario). -->
  <arg name="cbf_dykstra_warmstart" default="true"/>
  <arg name="cbf_final_constraint_mode" default="solver_bound"/>
  <arg name="cbf_multi_gradient_mode" default="analytical"/>
  <arg name="cbf_multi_fd_eps" default="0.001"/>
  <!-- Soft joint-limit barrier on the FINAL commanded velocity (both CUDA-
       graph and eager paths): each joint brakes as it approaches its URDF
       limit (allowed speed = kappa * distance-to-band) and gets a small
       bounded push back if it enters the band. On the Panda this IS the
       singularity guard: elbow-straight = q4 at its upper limit, wrist-
       aligned = q6 at its lower limit, so a 0.15 rad margin keeps the arm
       away from both regardless of who commands the motion (FM, router
       detour, escape, q_dot_clear). 0 = off. -->
  <arg name="cbf_joint_limit_margin" default="0.15"/>
  <arg name="cbf_joint_limit_kappa" default="3.0"/>
  <arg name="cbf_kappa" default="5.0"/>
  <arg name="cbf_recovery_kappa" default="5.0"/>
  <!-- Constraint-bound margin m [m/s]: the QP enforces hdot >= -kappa*h + m,
       so a nominal pushing at a wall settles at the standoff h* = m/kappa.
       0.001 parked the arm 0.2 mm from the certified boundary, where the
       certified reflex can admit almost no motion (any ZOH hold risks a
       curvature dip > h*): runPP1009-hard braked 50-76% of cycles at the
       graze. 0.025 -> h* = 5 mm, above the worst-case per-hold curvature
       dip c ~= 3.7 mm (fingers, 0.3 rad/s), which frees tangential grazes:
       replayed 9.9% braked, median alpha 1.0, no full stops
       (replay_reflex_alpha.py). Strictly tightens the constraint (m > 0
       implies the certified condition a fortiori); costs 5 mm of standoff
       in tight corridors. -->
  <arg name="cbf_constraint_margin" default="0.001"/>
  <!-- Sampled-data (ZOH) QP margin, A/B toggle. true = the constraint bound
       is tightened by the STATE-DEPENDENT term of the sampled-data CBF
       condition (Breeden, Garg & Panagou, L-CSS 2022) instead of relying on
       the constant margin above:  m(dq) = (L/2)||dq||^2 T  [m/s], with
       L = 20 (the reflex grad-Lipschitz constant) and T = 1/control_rate.
       This is the SAME certificate the certified reflex enforces post-hoc,
       applied where the decision is made: the QP then commands the largest
       hold-certifiable slide speed itself, instead of commanding a velocity
       the reflex must veto every tick (runPP1013: h parked at m/kappa =
       0.2 mm < the per-hold curvature dip, reflex braking 100% of ticks at
       alpha ~0.38). The standoff it buys is velocity-dependent and -> 0 at
       rest, i.e. earned, not a constant fudge. Logged per cycle as the
       'sampled_margin' diagnostics scalar (figure: sampled_margin.*). -->
  <arg name="cbf_sampled_data_margin" default="true"/>
  <!-- ISSf tracking-error margin (Kolathaya & Ames, IEEE L-CSS 2019): the
       plant executes dq = u + d, not the command (velocity-controller lag,
       output low-pass memory, reflex scaling), so every QP row is tightened
       by ||grad_h_row|| * epsilon to certify the TRUE flow. runPP1022 is the
       failure this closes: h dipped to -1.1 mm while the QP commanded
       OUTWARD every cycle (cmd_hdot +0.02 vs measured -0.02) - the dip was
       entirely unmodeled actuation mismatch. epsilon is the PROJECTED
       disturbance bound: the certificate only ever consumes grad_h . d, so
       the identified quantity is |cmd_hdot - real_hdot| / ||grad_h||, i.e.
       the mismatch measured ALONG the constraint direction, straight from
       the diagnostics log. runPP1023 v3: inward p95 0.011-0.018, p99 0.021
       rad/s, speed-INDEPENDENT (the tracking error is mostly filter lag
       along the tangential command direction; its grad_h component is
       small). 0.025 covers the p99 of every speed bin. The earlier
       norm-based eps(v) = 0.05 + 0.35v bounded the same quantity through
       Cauchy-Schwarz (worst case: error perfectly anti-aligned with
       grad_h) and over-charged 3-7x -> the 3.5 mm parked floor. rho stays
       available (eps(v) = eps0 + rho*v at the measured speed) but the
       identified projection needs no speed term. eps0=rho=0 = off. -->
  <arg name="cbf_issf_epsilon" default="0.025"/>
  <arg name="cbf_issf_rho" default="0.0"/>
  <!-- Linearization point of the margin/eps speed: "executed" =
       min(command-based v^2, (||dq_measured|| + headroom)^2). Fixes the two
       runPP1023 artifacts: the repair->margin feedback loop (published
       command 0.898 rad/s self-inflated the margin to its 0.08 cap ->
       worst_final_constraint -0.0455 while h was +5 mm and RISING) and the
       parked overcharge (margin linearized at the 0.46 rad/s NOMINAL while
       the arm executed 0.06 -> parked 6.8 mm out). headroom = identified
       per-hold speed INCREASE bound (accel-only p95 per >=33 ms:
       0.075-0.138 across runPP1022/23; braking cannot deepen the dip).
       "command" = legacy self-referential linearization. -->
  <arg name="cbf_sampled_data_linearization" default="executed"/>
  <arg name="cbf_sampled_data_vel_headroom" default="0.15"/>
  <!-- Per-link L for the sampled margin rows (cbf_link_names order, same
       constants as the reflex vector): arm links carry L 1.4-10 vs the
       global worst case 20, halving their standoff for free. -->
  <arg name="cbf_sampled_data_L_links" default="1.4 8.7 4.7 9.6 21.8 32.0 19.7 5 5"/>
  <!-- Final repair over ALL solve rows, not the min-h row alone. runPP1022
       tail: arm pinched between link4/link5 (cos(g4,g5) = -0.30, both
       h ~ -0.1 mm); the critical-row repair fixed link4 exactly and thereby
       pushed INTO link5 (-0.028 m/s violated every cycle) and the reflex
       rightly vetoed everything (alpha = 0 freeze) although a direction
       improving BOTH rows existed. All-rows repair re-runs the Dykstra
       sweeps on the post-filter command (in-graph, multi_graphed only). -->
  <arg name="cbf_repair_all_rows" default="true"/>
  <!-- Repair iterations, decoupled from the solve's 6. runPP1023 v6: the
       repair left a CONSTANT -0.003 residual through the 13 s graze (and
       -0.0012 on the small-gradient block) - the iterative tail of 6
       sweeps over task-metric-skewed opposing rows, re-paid every cycle.
       24 POCS sweeps of K tiny vector ops are sub-ms inside the graph and
       drive the tail below 1e-4. -->
  <arg name="cbf_repair_sweeps" default="24"/>
  <!-- Repair inner algorithm: dykstra = exact min-W-norm projection onto
       the row intersection (validated family, solver_study.py; smallest
       deviation from the near-optimal command). Requires exact per-row
       projections, so the grad-min gate is BINARY under it (row in/out at
       cbf_repair_grad_min) instead of the damped ramp that froze the
       Dykstra fixed point at gate*projection (runPP1023 v6). -->
  <arg name="cbf_repair_qp_algorithm" default="dykstra"/>
  <!-- dykstra = exact min-W-norm repair (solver_study.py-validated family;
       requires exact projections, so the grad-min gate is a binary row
       exclusion). pocs = feasibility-only fallback tolerating the damped
       gate ramp. -->
  <arg name="cbf_recovery_switch_margin" default="0.015"/>
  <arg name="cbf_enforce_final_constraint" default="true"/>
  <arg name="cbf_command_dt" default="0.05"/>
  <arg name="cbf_direct_position_mode" default="integrated"/>
  <arg name="cbf_position_correction_dt" default="0.02"/>
  <arg name="cbf_max_command_lead" default="0.05"/>
  <!-- TIGHTNESS: the active outside bound is the band
       -max_inward_speed * h / h_activate, so its slope [1/s] sets the
       equilibrium floor h* = (margins)/slope. The old 0.3/0.08 = 3.75 1/s
       multiplied the (honest, identified) margins into a 6.7 mm min_h and
       a slow asymptotic approach that reads as APF padding (runPP1023 v2).
       0.5/0.04 = 12.5 1/s parks the SAME certified margins at ~1-2 mm:
       tightness comes from allowing faster decay near the boundary, not
       from deleting safety. Keep cbf_reflex_exp_kappa >= this slope. -->
  <arg name="cbf_h_activate" default="0.04"/>
  <!-- Two-rate reflex brake (see green_cube_feeding_casf.launch): ~1 kHz
       h-extrapolation layer between the 100 Hz CBF-QP and the velocity
       controller. Off by default; inert diff when disabled. -->
  <arg name="enable_cbf_reflex" default="true"/>
  <arg name="cbf_reflex_rate_hz" default="1000.0"/>
  <!-- No horizon arg: the reflex MEASURES its own decision period and
       certifies only that (it re-decides every tick), so the guarantee no
       longer depends on the CBF solving within a hand-set latency. A slow
       QP just ages the state, which brakes harder on its own. Standoff is
       bought with cbf_reflex_h_stop (a distance), not a padded horizon. -->
  <arg name="cbf_reflex_h_stop" default="0.0"/>
  <!-- Must be STRICTLY GREATER than the QP band slope
       max_inward_speed/h_activate (12.5), with real gap - NOT equal.
       The QP runs 100% active in this scene and SATURATES its constraint
       (equality) whenever the nominal pushes at the wall, so its command
       decays h at exactly slope*h - margins. The reflex re-checks that
       command with extra remainder charges the QP does not carry (drift
       correction L*p.dq, unmeasured-gap ISSf charge, per-tick curvature):
       at exp_kappa = slope the certificate is tight-against-tight with
       ZERO slack and those charges tip every QP-legal command negative -
       runPP1023 v4 braked 74% of ticks / alpha ~ 0 the whole path, at any
       grad_lipschitz (L was never the binding term). The gap
       (exp_kappa - slope)*h + QP margins is the slack budget; full-bag
       replay: 12.5 -> 43.9% raw braking, 18.75 -> 2.6%, 25 -> 0.1%.
       Any exp_kappa > 0 yields the same forward-invariance guarantee
       (zeroing-CBF with class-K alpha(h) = exp_kappa*h); the QP's tighter
       band remains the shaping layer, the reflex the backstop for
       commands that escape certification (nested class-K layering, cf.
       Rosolia/Singletary/Ames multirate control). -->
  <arg name="cbf_reflex_exp_kappa" default="25.0"/>
  <!-- Reflex extrapolation mode. linear = legacy first-order estimate with
       the frozen gradient. certified = sampled-data CBF bound (Breeden,
       Garg & Panagou, "Control Barrier Functions in Sampled-Data Systems",
       IEEE L-CSS 2022): adds the Lipschitz remainder -(L/2)||dq*T||^2 so
       h >= h_stop is guaranteed over the WHOLE zero-order-hold interval,
       not just at the extrapolation endpoint; reduces to linear as L -> 0.
       Full derivation + assumptions + references: cbf_reflex_node.py
       docstring. grad_lipschitz L [m/rad^2] bounds ||grad_h(q)-grad_h(q')||
       / ||q-q'|| per row; validate against the empirical estimate in
       /cbf_reflex/status[4]. NOTE: the certificate assumes an unbiased h —
       pair with cbf_barrier_value_mode:=hard (the soft value under-reports
       clearance on the dense synthetic PP clouds and makes the brake fire
       on phantom proximity). -->
  <arg name="cbf_reflex_mode" default="certified"/>
  <!-- Per-link L [m/rad^2], cbf_link_names order (link2..7, hand, fingers).
       One-sided curvature sups of the deployed analytic barrier, sampled
       offline (sdf_gradient_experiments/lipschitz_bound_study.py, 8192
       configs, rounded up). The finger 600s assume the n_func=12 candidate
       models below; with production n_func=8 fingers use 850. A scalar
       value is still accepted (legacy global constant). -->
  <!--arg name="cbf_reflex_grad_lipschitz" default="5 35 25 30 85 85 50 5 5"/-->
  <!-- Per-link vector NOW ACTIVE (was scalar 10; runPP1023 ran an
       effective scalar 5 and the empirical estimate exceeded it on 40% of
       near-barrier updates, p95 15.2 / max 43 - certificate assumption
       (ii) was measurably violated). These are the nfunc12-candidate sups
       matching the active cbf_model_override_dir below. -->
  <!--arg name="cbf_reflex_grad_lipschitz" default="1.4 8.7 4.7 9.6 21.8 32.0 19.7 5 5"/-->
  <arg name="cbf_reflex_grad_lipschitz" default="10"/>
  <!-- Retrained n_func=12 finger RDFs (validated 2026-07-14: MAE halved to
       0.61 mm, p95 gradient angle 124->41 deg, negative curvature sup
       840->508 vs production n_func=8). Empty string = production models. -->
  <arg name="cbf_model_override_dir"
       default="$(find vision_processing)/third_party/SDF_Bernstein_Basis/panda_test/Models/nfunc12_candidate"/>
  <arg name="cbf_model_override_links" default="panda_leftfinger panda_rightfinger"/>
  <!-- Raised with the h_activate reduction: band slope 0.5/0.04 = 12.5 1/s
       (see the TIGHTNESS comment at cbf_h_activate). -->
  <arg name="cbf_max_inward_speed" default="0.5"/>
  <arg name="cbf_recovery_speed" default="0.05"/>
  <arg name="cbf_recovery_depth" default="0.015"/>
  <!-- Raised from 0.3: the task-metric correction has larger joint-space
       norms, and the dynamic-hdot bound needs correction authority scaling
       with obstacle speed (see run101 constr_final analysis in feeding). -->
  <arg name="cbf_max_correction_speed" default="0.5"/>
  <arg name="cbf_recovery_max_correction_speed" default="0.5"/>
  <arg name="cbf_repair_grad_min" default="0.03"/>
  <arg name="cbf_projection_iters" default="3"/>
  <arg name="cbf_projection_relaxation" default="1.0"/>
  <arg name="cbf_tracking_feedback_mode" default="tangent_near"/>
  <!-- QP projection metric ablation. identity = legacy Euclidean min-norm
       (correction lands on the joint with the largest moment arm on the
       barrier, e.g. joint 2 pulling the shoulder back in runPP13). task =
       weighted by W^-1 with W = Jp^T Jp + w_rot Jo^T Jo + lambda I of the
       controlled link (panda_TCP): the same half-space is enforced, but the
       correction prefers the TCP null space (elbow swivel), minimizing the
       deviation of the executed TCP path from the FM nominal. -->
  <arg name="cbf_projection_metric" default="task"/>
  <arg name="cbf_task_metric_lambda" default="0.01"/>
  <arg name="cbf_task_metric_rot_weight" default="0.05"/>
  <!-- Decimation is per PREPROCESS TICK, not per second, so it has to track
       cbf_preprocess_rate_hz. 3 @ 100 Hz = the same ~33 Hz refresh this ran
       at when the tick was 30 Hz; leaving it at 1 would silently triple the
       rate instead. That matters more than it looks: _update_task_metric
       does a .cpu() on the FD-FK poses = a hard D2H sync, the exact thing
       the graphed selection exists to avoid, and it sits BEFORE the
       critical_point_selection timer's t_start so it is invisible in that
       stat. The metric is a slowly-varying preconditioner (its docstring
       budgets <=33 ms staleness = <0.025 rad), so 33 Hz is by design, not
       incidental. Back to 1 if cbf_preprocess_rate_hz goes back to 30. -->
  <arg name="cbf_task_metric_update_every" default="3"/>
  <!-- Active null-space clearance: the QP only cancels inward velocity, so a
       nominal pushing a body link at an obstacle parks the arm at h~0 forever.
       This drive adds gain * proximity * N grad_h BEFORE the QP: the posture
       deforms away from the critical obstacle (elbow swivel, TCP unchanged)
       as soon as h < the activate distance, unblocking the path instead of
       stalling on it. The swivel speed tops out at the gain [rad/s]. 0 = off.
       Requires cbf_projection_metric task. -->
  <arg name="cbf_nullspace_clearance_gain" default="0.3"/>
  <arg name="cbf_nullspace_clearance_h_activate" default="0.05"/>
  <!-- CASF Riemannian warp kept OFF: too slow at runtime. TCP-path blocks are
       handled reactively instead, by the CBF escape with the probed
       tangential direction (below). -->
  <arg name="enable_casf_correction" default="false"/>
  <!-- Deadlock escape for obstacles blocking the TCP path itself (runPP14:
       cube->box transport pinned 40 s at the prism wall; the barrier gradient
       only pushes BACK, and null-space deformation has no authority on a
       hand-borne constraint). When stuck near the barrier, add a velocity
       TANGENT to the barrier (g^T dq = 0, so it costs nothing in safety, and
       the QP still filters it against all other links). The DIRECTION is
       chosen by the sampled-clearance probe (probe_enabled): K tangent-plane
       directions are virtually stepped by probe_radii and scored by clearance
       against the obstacle cloud + nominal-velocity alignment + a commitment
       bonus (hysteresis, no side-flipping) - a floor penalty (the table is
       not in the cloud). Runs at ~30 Hz in the preprocess thread; the 100 Hz
       graph consumes the staged joint row unchanged. probe_enabled false
       falls back to the old fixed +z lift. lift_gain stays the authority
       [rad/s]. Deactivates at h > h_release. -->
  <!-- Escape stack disabled for the thesis-canonical configuration (2026-07-13):
       frontal blockage of the controlled link = assumed safe-stop limitation
       (thesis ch. 4 garanties). q_dot_clear (nullspace clearance) stays ON. -->
  <arg name="cbf_escape_enabled" default="false"/>
  <arg name="cbf_escape_h_trigger" default="0.02"/>
  <arg name="cbf_escape_h_release" default="0.12"/>
  <arg name="cbf_escape_lift_gain" default="0.2"/>
  <arg name="cbf_escape_max_velocity" default="0.15"/>
  <!-- Retreat term for concave pockets (crescent bite): pushes along grad_h
       (out through the pocket mouth) whenever h < normal_h_trigger. The probe
       only searches the TANGENT plane, so without this the only exit
       direction (+normal) is unreachable and the robot rides the vertical
       groove up/down forever. Node defaults were 0.04 / 0.0 (i.e. inert:
       active only once h < 0). -->
  <!-- Keep the normal (retreat) term a gentle NUDGE. Large values saturate
       the escape_max_velocity clamp and turn the whole escape into a pure
       hard retreat, overriding the probe's voted direction (no exploration,
       maximum pump violence). The probe + suppress_nominal do the real
       backing-out work now. -->
  <arg name="cbf_escape_normal_gain" default="0.0"/>
  <arg name="cbf_escape_normal_h_trigger" default="0.03"/>
  <arg name="cbf_escape_tangent_gain" default="1.0"/>
  <!-- Proportional escape gate time constant [s]. The escape is no longer a
       binary latch: its authority ramps with h-proximity, gated by actual
       CBF conflict, EMA-filtered with this tau. It self-regulates to a
       partial-authority equilibrium (the smooth version of what the old
       flickering trigger did by accident) instead of chattering or latching
       at full power (runPP1002: 30 s wrestling match, wiggle, h < 0). -->
  <arg name="cbf_escape_gate_tau" default="0.3"/>
  <arg name="cbf_escape_probe_enabled" default="false"/>
  <arg name="cbf_escape_probe_num_dirs" default="16"/>
  <!-- Long radii = the probe's planning horizon. With 0.05/0.10 only, every
       tangent direction along a 0.2 m-wide wall scores as an identical
       corridor and "around" (the x-edge ~12-15 cm away) can never win the
       vote (runPP1002.3ag: climbed the 1 m wall and parked at the kinematic
       ceiling). 0.20/0.30 lets lateral directions see past the edge, where
       the growth term rewards them. -->
  <arg name="cbf_escape_probe_radii" default="0.05 0.10 0.20 0.5"/>
  <!-- Concave-pocket escape machinery (hemisphere elevations + clearance-
       growth scoring + nominal-inward suppression), now OFF: the via-point
       router owns the "find a way around" job. Left enabled they FIGHT the
       normal barrier graze along a routed path: runPP1005 rode h~0.001 over
       the 0.36 m wall (expected: body links pass inside the CBF band even
       though the TCP corridor clears), the escape gate charged to ~0.9, the
       hemisphere probe voted pure retreat (best clearance growth is always
       +normal) and suppression cancelled the nominal -> |dq_escape| spikes
       of 0.6+ rad/s = the "huge push in the prism normal". "0"/0.0/0.0 =
       legacy gentle nudge (tangent slide + probed lift only). Restore
       "0 30 60"/1.0/1.0 only when running WITHOUT the router. -->
  <arg name="cbf_escape_probe_elevations" default="0"/>
  <arg name="cbf_escape_probe_growth_weight" default="0.0"/>
  <arg name="cbf_escape_suppress_nominal" default="0.0"/>
  <arg name="cbf_escape_probe_clearance_cap" default="0.20"/>
  <arg name="cbf_escape_probe_goal_weight" default="0.02"/>
  <arg name="cbf_escape_probe_commit_weight" default="0.02"/>
  <!-- Table top is z=0 in the CBF/world frame here. -->
  <arg name="cbf_escape_probe_min_z" default="0.03"/>
  <arg name="cbf_escape_probe_ema" default="0.3"/>
  <!-- Tabu re-vote for concave obstacles (crescent bite): if the committed
       escape direction yields < tabu_min_progress of TCP motion along itself
       for tabu_timeout seconds (QP-clipped: wedged), it is penalized for
       tabu_ttl seconds and the probe re-votes. Progress = displacement along
       the direction, not h (a good tangential escape slides at h~trigger). -->
  <arg name="cbf_escape_probe_tabu_timeout" default="1.5"/>
  <arg name="cbf_escape_probe_tabu_min_progress" default="0.03"/>
  <!-- 0.2 (was 0.1): a tabu'd direction must lose even to alternatives whose
       clearance-growth score is ~0.1 lower (retreat vs lateral at a wall),
       or the vote just re-picks the tabu'd one. -->
  <arg name="cbf_escape_probe_tabu_weight" default="0.8"/>
  <arg name="cbf_escape_probe_tabu_ttl" default="8.0"/>
  <!-- Escape stack shrunk to a minimal smooth nudge: the via-point detour
       layer now owns the "find a way around" job at the trajectory level,
       so the speculative exploration machinery is OFF (resolve_timeout and
       reentry_window at 0 = disabled). The proportional gate + probe + the
       simple stall tabu remain as the local deadlock safety net. -->
  <arg name="cbf_escape_probe_resolve_timeout" default="0.0"/>
  <arg name="cbf_escape_probe_reentry_window" default="0.0"/>
  <!-- Exact hard-min barrier VALUE (Softmin keeps supplying the gradient):
       the PP obstacle clouds are dense/synthetic, so the Softmin crowding
       bias otherwise under-reports clearance by ~alpha*log(N) = 9.2 mm.
       REQUIRED by the certified reflex (assumption (iii) in
       cbf_reflex_node.py): runPP1009 ran soft and the reflex braked 77% of
       cycles (median alpha 0.37) on a phantom h~0.5 mm graze whose unbiased
       clearance was ~9 mm; replayed hard, the same per-link constants brake
       36% at median alpha 1.0 (replay_reflex_alpha.py). + time-varying CBF
       tightening for a moving sphere (inert while sphere velocity is 0). -->
  <arg name="cbf_barrier_value_mode" default="hard"/>
  <arg name="cbf_dynamic_hdot_enabled" default="true"/>
  <arg name="cbf_dynamic_hdot_tau" default="0.05"/>
  <arg name="cbf_dynamic_hdot_deadband" default="0.05"/>
  <arg name="cbf_dynamic_hdot_max" default="0.5"/>
  <arg name="cbf_passthrough_when_inactive" default="true"/>
  <arg name="cbf_monitor_only" default="false"/>
  <arg name="cbf_filter_tau" default="0.08"/>
  <arg name="cbf_velocity_filter_tau" default="0.1"/>
  <arg name="cbf_diagnostics_decimation" default="4"/>
  <arg name="barrier_alpha" default="0.002"/>
  <arg name="d_safe" default="0.015"/>

  <!-- Trajectory retiming (was using the planner's internal defaults: joint_speed
       @ 0.25 rad/s = slow). Raise trajectory_retime_joint_speed to go faster; the
       max joint then moves at this rad/s. Keep it <= the tracker's
       max_joint_velocity (0.7) or the arm lags the nominal. -->
  <arg name="trajectory_retime_mode" default="joint_speed"/>
  <arg name="trajectory_retime_joint_speed" default="0.3"/>
  <arg name="trajectory_retime_joint_weights" default="1 1 1 1 1 1 1"/>
  <arg name="trajectory_retime_min_segment_fraction" default="0.02"/>
  <arg name="trajectory_waypoint_rate_hz" default="10.0"/>

  <!-- Temporal ensembler: the FM pick-place policy is MULTIMODAL (offline you see
       up- and down-branches from the same scene). Re-querying it every cycle lets
       it flip mode at the grasp/bottom. Ensembling blends each future timestep over
       the last few plans (weight = exp(-decay * age_s)) so an occasional off-mode
       sample is outvoted by the consistent one. Set false to A/B the raw policy. -->
  <arg name="use_temporal_ensembler" default="false"/>
  <arg name="ensembler_buffer_size" default="5"/>
  <arg name="ensembler_decay" default="1.5"/>
  <arg name="trajectory_command_lookahead_time" default="0.05"/>

  <!-- Static-camera topics (perception runs on the STATIC cam this time). -->
  <arg name="static_rgb_topic"   default="/camera_static/color/image_raw"/>
  <arg name="static_depth_topic" default="/camera_static/aligned_depth_to_color/image_raw"/>
  <arg name="static_info_topic"  default="/camera_static/color/camera_info"/>
  <arg name="static_cam_frame"   default="camera_static_optical_frame"/>

  <!-- 0. Gazebo env + gripper Panda + cameras + velocity controller + sam3_server -->
  <include file="$(find vision_processing)/launch/pickplace_simulation.launch">
    <arg name="gui" value="$(arg gui)"/>
    <arg name="launch_sam3_server" value="$(arg launch_sam3_server)"/>
    <arg name="use_direct_group_velocity_controller" value="true"/>
    <arg name="obstacle_enabled" value="$(arg obstacle_enabled)"/>
    <arg name="obstacle_shape" value="$(arg obstacle_shape)"/>
    <arg name="obstacle_x" value="$(arg obstacle_x)"/>
    <arg name="obstacle_y" value="$(arg obstacle_y)"/>
    <arg name="obstacle_yaw" value="$(arg obstacle_yaw)"/>
    <arg name="obstacle_radius" value="$(arg obstacle_radius)"/>
    <arg name="obstacle_height" value="$(arg obstacle_height)"/>
    <arg name="obstacle_prism_height" value="$(arg obstacle_prism_height)"/>
    <arg name="obstacle_gazebo_z" value="$(arg obstacle_gazebo_z)"/>
    <arg name="obstacle_prism_size_x" value="$(arg obstacle_prism_size_x)"/>
    <arg name="obstacle_prism_size_y" value="$(arg obstacle_prism_size_y)"/>
  </include>

  <!-- 0.5. Camera-independent obstacle cloud for the online CBF. This mirrors
       the spawned static obstacle and can add a synthetic moving sphere in the
       robot/table world frame. -->
  <node name="pp_static_obstacle" pkg="vision_processing"
        type="static_cylinder_obstacle_pp.py" output="screen"
        if="$(arg obstacle_enabled)">
        <param name="frame_id" value="world"/>
        <param name="shape" value="$(arg obstacle_shape)"/>
        <param name="topic" value="$(arg obstacle_cloud_topic)"/>
        <param name="extra_topic" value="$(arg obstacle_cloud_extra_topic)"/>
        <param name="center_x" value="$(arg obstacle_x)"/>
        <param name="center_y" value="$(arg obstacle_y)"/>
        <param name="yaw" value="$(arg obstacle_yaw)"/>
        <param name="base_z" value="0.0"/>
        <param name="radius" value="$(arg obstacle_radius)"/>
        <param name="height"
               value="$(eval float(arg('obstacle_prism_height')) if arg('obstacle_shape') == 'prism' else float(arg('obstacle_height')))"/>
        <param name="prism_size_x" value="$(arg obstacle_prism_size_x)"/>
        <param name="prism_size_y" value="$(arg obstacle_prism_size_y)"/>
        <param name="crescent_outer_radius" value="$(arg obstacle_crescent_outer_radius)"/>
        <param name="crescent_inner_radius" value="$(arg obstacle_crescent_inner_radius)"/>
        <param name="crescent_bite_offset" value="$(arg obstacle_crescent_bite_offset)"/>
        <param name="num_points" value="$(arg obstacle_cloud_points)"/>
        <param name="moving_sphere_enabled" value="$(arg moving_sphere_enabled)"/>
        <param name="moving_sphere_initial_x" value="$(arg moving_sphere_initial_x)"/>
        <param name="moving_sphere_initial_y" value="$(arg moving_sphere_initial_y)"/>
        <param name="moving_sphere_initial_z" value="$(arg moving_sphere_initial_z)"/>
        <param name="moving_sphere_velocity_x" value="$(arg moving_sphere_velocity_x)"/>
        <param name="moving_sphere_velocity_y" value="$(arg moving_sphere_velocity_y)"/>
        <param name="moving_sphere_velocity_z" value="$(arg moving_sphere_velocity_z)"/>
        <param name="moving_sphere_radius" value="$(arg moving_sphere_radius)"/>
        <param name="moving_sphere_num_points" value="$(arg moving_sphere_num_points)"/>
        <param name="gazebo_mirror_enabled" value="$(arg moving_sphere_gazebo_mirror)"/>
        <param name="gazebo_z_offset" value="0.75"/>
        <param name="publish_rate_hz" value="30.0"/>
  </node>

  <!-- 1. SAM3 + SAM2 detect/track TWO objects (cube + box) on the static cam. -->
  <node name="sam3_sam2_pp" pkg="vision_processing" type="sam3_sam2_node_pp.py" output="screen" cwd="node">
        <env name="PYTORCH_CUDA_ALLOC_CONF" value="$(arg pytorch_cuda_alloc_conf)"/>
        <!-- GPU-bound node: cap the OMP intra-op pool so three torch
             processes stop oversubscribing the 12 CPU cores (each defaults
             to 12 spin-waiting threads), which inflated every eager-op
             dispatch in the 100 Hz CBF loop to ~80 us. -->
        <env name="OMP_NUM_THREADS" value="2"/>
        <param name="cube_prompt" value="$(arg cube_prompt)"/>
        <param name="box_prompt"  value="$(arg box_prompt)"/>
        <param name="camera_frame" value="$(arg static_cam_frame)"/>
        <param name="rgb_topic" value="$(arg static_rgb_topic)"/>
  </node>

  <!-- 2a. Projector: cube mask -> /perception/target_cube -->
  <node name="projector_cube" pkg="vision_processing" type="point_cloud_projector_node.py" output="screen" cwd="node">
        <param name="target_frame" value="world"/>
        <param name="camera_frame" value="$(arg static_cam_frame)"/>
        <param name="depth_topic" value="$(arg static_depth_topic)"/>
        <param name="info_topic"  value="$(arg static_info_topic)"/>
        <param name="rgb_topic"   value="$(arg static_rgb_topic)"/>
        <param name="mask_topic"  value="/vision/sam2_mask_cube"/>
        <param name="enable_fork_sam3_mask" value="false"/>
        <param name="fork_sdf_filter" value="false"/>
        <param name="enable_fork_filter" value="false"/>
        <remap from="/perception/target" to="/perception/target_cube"/>
        <remap from="/perception/obstacles" to="/perception/obstacles_cube"/>
  </node>

  <!-- 2b. Projector: box mask -> /perception/target_box -->
  <node name="projector_box" pkg="vision_processing" type="point_cloud_projector_node.py" output="screen" cwd="node">
        <param name="target_frame" value="world"/>
        <param name="camera_frame" value="$(arg static_cam_frame)"/>
        <param name="depth_topic" value="$(arg static_depth_topic)"/>
        <param name="info_topic"  value="$(arg static_info_topic)"/>
        <param name="rgb_topic"   value="$(arg static_rgb_topic)"/>
        <param name="mask_topic"  value="/vision/sam2_mask_box"/>
        <param name="enable_fork_sam3_mask" value="false"/>
        <param name="fork_sdf_filter" value="false"/>
        <param name="enable_fork_filter" value="false"/>
        <remap from="/perception/target" to="/perception/target_box"/>
        <remap from="/perception/obstacles" to="/perception/obstacles_box"/>
  </node>

  <!-- 2c. Ground-truth cube cloud (use_gt_cube:=true): full box surface at the
       live Gazebo pose of red_cube, published beside the SAM cloud. -->
  <node name="gt_cube_cloud" pkg="vision_processing" type="gt_cube_cloud_node.py"
        output="screen" if="$(arg use_gt_cube)">
        <param name="model_name" value="red_cube"/>
        <param name="topic" value="/perception/target_cube_gt"/>
        <param name="world_frame" value="world"/>
        <param name="table_z_offset" value="0.75"/>
        <!-- Real Gazebo cube: 0.04 x 0.04 x 0.06. Training cube was 0.04^3;
             set half_z to 0.02 to reproduce the training size instead. -->
        <param name="half_x" value="0.02"/>
        <param name="half_y" value="0.02"/>
        <param name="half_z" value="0.03"/>
        <param name="num_points" value="600"/>
  </node>

  <!-- 3. Conditioning: gripper + cube + box -> /vision/merged_cloud (world) -->
  <node name="condition_pickplace" pkg="vision_processing" type="condition_pcd_pickplace.py" output="screen">
        <param name="num_points" value="$(arg condition_num_points)"/>
        <param name="world_frame" value="world"/>
        <param name="tcp_frame" value="panda_TCP"/>
        <param name="cube_topic" value="/perception/target_cube_gt" if="$(arg use_gt_cube)"/>
        <param name="cube_topic" value="/perception/target_cube" unless="$(arg use_gt_cube)"/>
  </node>

  <!-- 4. CASF generative planner, reused for the pick-and-place policy.
       controlled_link:=panda_TCP -> the model predicts the TCP directly;
       cbf_link_names without fork_tip -> gripper robot model. CASF correction
       remains off; the online CBF node handles obstacle avoidance. -->
  <node name="safe_generative_planner" pkg="vision_processing" type="casf_generative_node_PC_pp.py" output="screen" cwd="node">
        <!-- With the via-point router enabled, the planner publishes RAW and
             the router owns /planner/nominal_trajectory. -->
        <remap from="/planner/nominal_trajectory" to="/planner/raw_nominal_trajectory"
               if="$(arg enable_viapoint_detour)"/>
        <env name="PYTORCH_CUDA_ALLOC_CONF" value="$(arg pytorch_cuda_alloc_conf)"/>
        <!-- Same OMP cap as sam3_sam2_pp: keep CPU cores for the 100 Hz CBF loop. -->
        <env name="OMP_NUM_THREADS" value="2"/>
        <param name="model_name" value="$(arg pickplace_model_name)"/>
        <param name="urdf_path" value="$(find vision_processing)/urdf/panda_pickplace.xacro"/>
        <param name="controlled_link" value="panda_TCP"/>
        <rosparam param="cbf_link_names">['panda_link2', 'panda_link3', 'panda_link4','panda_link5','panda_link6','panda_link7','panda_hand','panda_rightfinger','panda_leftfinger']</rosparam>
        <param name="merged_cloud_contains_fork" value="true"/>
        <param name="tcp_frame" value="panda_TCP"/>
        <param name="gripper_open_threshold" value="0.03"/>
        <param name="wait_for_cbf_ready" value="true"/>
        <!-- Warp off by default (too slow online). runPP14 showed the failure
             this leaves: the obstacle-blind policy demands cube->box THROUGH
             the prism wall and the TCP parks there. Handled reactively by the
             CBF escape lift (cbf_escape_lift_gain) instead. -->
        <param name="enable_casf_correction" value="$(arg enable_casf_correction)"/>
        <param name="planner_rate_hz" value="$(arg planner_rate_hz)"/>
        <param name="trajectory_retime_mode" value="$(arg trajectory_retime_mode)"/>
        <param name="trajectory_retime_joint_speed" value="$(arg trajectory_retime_joint_speed)"/>
        <param name="trajectory_retime_joint_weights" value="$(arg trajectory_retime_joint_weights)"/>
        <param name="trajectory_retime_min_segment_fraction" value="$(arg trajectory_retime_min_segment_fraction)"/>
        <param name="trajectory_waypoint_rate_hz" value="$(arg trajectory_waypoint_rate_hz)"/>
        <param name="use_temporal_ensembler" value="$(arg use_temporal_ensembler)"/>
        <param name="ensembler_buffer_size" value="$(arg ensembler_buffer_size)"/>
        <param name="ensembler_decay" value="$(arg ensembler_decay)"/>
        <param name="single_shot" value="$(arg single_shot)"/>
        <param name="log_trajectory_timing" value="false"/>
        <!-- ENABLED (2026-07): torch.compile reduce-overhead CUDA-graphs each
             velocity_net forward, collapsing the FM burst from ~85 ms to
             ~15-20 ms. That burst is the dominant source of the CBF's p95/max
             command-readback tail (fm_generation med 87 ms, p95 148 ms; the
             planner is a SEPARATE process/CUDA context so the CBF priority
             stream cannot preempt it, so shrinking the burst is the only
             cross-context lever short of MPS). Math unchanged (same fp32).
             The historical `_is_key_in_tls` blocker (capture thread != replay
             thread) is fixed in casf_generative_node_PC_pp.py: the warmup now
             runs on the first control_loop tick, inside the rospy.Timer
             thread that also does every replay. Any compile/capture failure
             falls back to the eager net automatically. Feeding is untouched
             (different planner file, still eager). -->
        <param name="fm_use_torch_compile" value="true"/>
  </node>

  <!-- 4.5. Via-point detour router (see enable_viapoint_detour above). -->
  <node name="viapoint_detour" pkg="vision_processing" type="viapoint_detour_node_pp.py"
        output="screen" cwd="node" if="$(arg enable_viapoint_detour)">
        <param name="enabled" value="false"/>
        <param name="input_topic" value="/planner/raw_nominal_trajectory"/>
        <param name="output_topic" value="/planner/nominal_trajectory"/>
        <param name="obs_topic" value="$(arg obstacle_cloud_topic)"/>
        <param name="urdf_path" value="$(find vision_processing)/urdf/panda_pickplace.xacro"/>
        <param name="tcp_link" value="panda_TCP"/>
        <!-- TCP-point corridor for "blocked" / for the detour legs: generous
             vs the CBF's whole-body d_safe because these are point checks
             and the hand needs a gripper half-width of room. -->
        <param name="block_margin" value="0.10"/>
        <param name="leg_margin" value="0.09"/>
        <param name="via_margin" value="0.15"/>
        <param name="retime_joint_speed" value="$(arg trajectory_retime_joint_speed)"/>
        <!-- Success-side hysteresis: forget the committed route only after
             the planner's path has been continuously clear this long, so
             3 Hz blocked/clear flicker can't flip the chosen side. -->
        <param name="commit_clear_time" value="20.0"/>
        <!-- Reactive-first balance: while blocked, the CBF slide +
             q_dot_clear get first shot; the router only engages once the
             TCP has moved < activation_min_progress for activation_stuck_
             time s (= truly stuck in the local minimum, the runPP1002.3ag
             signature). Low prism: the graze-over progresses and the router
             never fires. 0.0 = engage on the first blocked plan. -->
        <param name="activation_stuck_time" value="4.0"/>
        <param name="activation_min_progress" value="0.03"/>
        <!-- Stall re-vote: the route check is a TCP-point corridor, blind to
             whole-body feasibility. No TCP progress toward the current via
             for stall_timeout s => tabu that route stall_tabu_ttl s and
             re-vote (next-best side gets a turn). 0 = off. -->
        <!-- Kinematic-quality gate: a detour whose IK path comes within
             limit_margin_rad of a joint limit or drops below sing_min_sigma
             of positional-Jacobian manipulability is rejected AND tabu'd
             (vote moves to the other side) instead of driving the arm into
             a singularity. Raise sing_min_sigma if singular configs still
             slip through; 0 disables the singularity check. -->
        <param name="sing_min_sigma" value="0.04"/>
        <param name="limit_margin_rad" value="0.05"/>
        <param name="stall_timeout" value="4.0"/>
        <param name="stall_min_progress" value="0.02"/>
        <param name="stall_tabu_ttl" value="12.0"/>
        <param name="publish_viz" value="$(arg launch_rviz)"/>
  </node>

  <!-- 5. Execution = the SAME chain as feeding: executor retimes the trajectory and
       publishes the nominal joint POSITION + VELOCITY; the CBF node (5.1) closes the
       loop to the velocity controller (feedforward + position feedback) and adds
       safety once an obstacle source is wired. -->
  <node name="trajectory_executor" pkg="vision_processing" type="trajectory_executor.py" output="screen"
        if="$(arg execute)">
        <param name="rate_hz" value="$(arg control_rate_hz)"/>
        <param name="out_topic" value="/planner/nominal_joint_command"/>
        <param name="velocity_out_topic" value="/planner/nominal_joint_velocity"/>
        <param name="hold_current_until_trajectory" value="true"/>
        <param name="use_progress_clock" value="true"/>
        <param name="progress_lag_limit_rad" value="0.25"/>
        <!-- Freeze trajectory progress while the barrier is violated (h < 0)
             so the nominal doesn't run ahead during a CBF deflection; the arm
             resumes the planned path where it left it. -->
        <param name="cbf_hold_threshold" value="0.0"/>
        <param name="anchor_mode" value="start"/>
        <param name="command_lookahead_time" value="$(arg trajectory_command_lookahead_time)"/>
        <param name="log_timing" value="false"/>
  </node>

  <!-- 5.1. Online CBF safety shield. Same CBF implementation as feeding, but with
       the pick-place URDF, TCP frame, gripper/finger SDF links, and the static
       cylinder obstacle cloud. -->
  <node name="cbf_safety_Bernstein" pkg="vision_processing" type="$(arg cbf_node_type)"
        output="screen" cwd="node" if="$(arg execute)">
        <remap from="/joint_group_velocity_controller/command"
               to="/cbf_safety/pre_reflex_command"
               if="$(arg enable_cbf_reflex)"/>
        <env name="PYTORCH_CUDA_ALLOC_CONF" value="$(arg pytorch_cuda_alloc_conf)"/>
        <param name="cbf_reflex_publish" value="$(arg enable_cbf_reflex)"/>
        <param name="urdf_path" value="$(find vision_processing)/urdf/panda_pickplace.xacro"/>
        <param name="controlled_link" value="panda_TCP"/>
        <rosparam param="cbf_link_names">['panda_link2', 'panda_link3', 'panda_link4','panda_link5','panda_link6','panda_link7','panda_hand','panda_rightfinger','panda_leftfinger']</rosparam>
        <param name="enable_cbf" value="$(arg enable_cbf)"/>
        <param name="model_override_dir" value="$(arg cbf_model_override_dir)"/>
        <param name="model_override_links" value="$(arg cbf_model_override_links)"/>
        <param name="cbf_passthrough_when_inactive" value="$(arg cbf_passthrough_when_inactive)"/>
        <param name="cbf_monitor_only" value="$(arg cbf_monitor_only)"/>
        <param name="cbf_graph_points" value="$(arg cbf_graph_points)"/>
        <param name="preprocess_max_points" value="$(arg cbf_preprocess_max_points)"/>
        <param name="cbf_candidate_filter" value="$(arg cbf_candidate_filter)"/>
        <param name="cbf_selection_metric" value="$(arg cbf_selection_metric)"/>
        <param name="cbf_cluster_mode" value="$(arg cbf_cluster_mode)"/>
        <param name="cbf_selection_mode" value="$(arg cbf_selection_mode)"/>
        <param name="cbf_sdf_graph_points" value="$(arg cbf_sdf_graph_points)"/>
        <param name="preprocess_rate_hz" value="$(arg cbf_preprocess_rate_hz)"/>
        <param name="cbf_sdf_candidate_max_dist" value="$(arg cbf_sdf_candidate_max_dist)"/>
        <param name="cbf_sdf_prune_chunk_size" value="$(arg cbf_sdf_prune_chunk_size)"/>
        <param name="cbf_sdf_self_filter_margin" value="$(arg cbf_sdf_self_filter_margin)"/>
        <param name="cbf_sdf_prefilter_radius" value="$(arg cbf_sdf_prefilter_radius)"/>
        <param name="cbf_sdf_prefilter_max_points" value="$(arg cbf_sdf_prefilter_max_points)"/>
        <param name="cbf_solver_mode" value="$(arg cbf_solver_mode)"/>
        <param name="cbf_active_constraints" value="$(arg cbf_active_constraints)"/>
        <param name="cbf_separate_streams" value="$(arg cbf_separate_streams)"/>
        <param name="cbf_graphed_control_step" value="$(arg cbf_graphed_control_step)"/>
        <param name="cbf_constraint_sweeps" value="$(arg cbf_constraint_sweeps)"/>
        <param name="cbf_qp_algorithm" value="$(arg cbf_qp_algorithm)"/>
        <param name="cbf_dykstra_warmstart" value="$(arg cbf_dykstra_warmstart)"/>
        <param name="cbf_final_constraint_mode" value="$(arg cbf_final_constraint_mode)"/>
        <param name="cbf_multi_gradient_mode" value="$(arg cbf_multi_gradient_mode)"/>
        <param name="cbf_multi_fd_eps" value="$(arg cbf_multi_fd_eps)"/>
        <param name="cbf_grasp_box_enabled" value="false"/>
        <param name="obs_topic" value="$(arg obstacle_cloud_topic)"/>
        <!-- Drive the velocity controller, exactly like feeding. -->
        <param name="publish_controller_command" value="false"/>
        <param name="publish_velocity_controller_command" value="true"/>
        <param name="rate_hz" value="$(arg control_rate_hz)"/>
        <!-- Tracking law (identical gains to feeding / the old velocity_tracker_pp). -->
        <param name="cbf_kp" value="5.0"/>
        <param name="max_feedback_velocity" value="0.5"/>
        <param name="cbf_filter_tau" value="$(arg cbf_filter_tau)"/>
        <param name="cbf_velocity_filter_tau" value="$(arg cbf_velocity_filter_tau)"/>
        <param name="max_joint_velocity" value="$(arg max_joint_velocity)"/>
        <param name="cbf_joint_limit_margin" value="$(arg cbf_joint_limit_margin)"/>
        <param name="cbf_joint_limit_kappa" value="$(arg cbf_joint_limit_kappa)"/>
        <param name="cbf_kappa" value="$(arg cbf_kappa)"/>
        <param name="cbf_recovery_kappa" value="$(arg cbf_recovery_kappa)"/>
        <param name="cbf_constraint_margin" value="$(arg cbf_constraint_margin)"/>
        <param name="cbf_sampled_data_margin" value="$(arg cbf_sampled_data_margin)"/>
        <param name="cbf_issf_epsilon" value="$(arg cbf_issf_epsilon)"/>
        <param name="cbf_issf_rho" value="$(arg cbf_issf_rho)"/>
        <param name="cbf_sampled_data_linearization" value="$(arg cbf_sampled_data_linearization)"/>
        <param name="cbf_sampled_data_vel_headroom" value="$(arg cbf_sampled_data_vel_headroom)"/>
        <param name="cbf_sampled_data_L_links" value="$(arg cbf_sampled_data_L_links)"/>
        <param name="cbf_repair_all_rows" value="$(arg cbf_repair_all_rows)"/>
        <param name="cbf_repair_sweeps" value="$(arg cbf_repair_sweeps)"/>
        <param name="cbf_repair_qp_algorithm" value="$(arg cbf_repair_qp_algorithm)"/>
        <param name="cbf_recovery_switch_margin" value="$(arg cbf_recovery_switch_margin)"/>
        <param name="cbf_enforce_final_constraint" value="$(arg cbf_enforce_final_constraint)"/>
        <param name="cbf_command_dt" value="$(arg cbf_command_dt)"/>
        <param name="cbf_direct_position_mode" value="$(arg cbf_direct_position_mode)"/>
        <param name="cbf_position_correction_dt" value="$(arg cbf_position_correction_dt)"/>
        <param name="cbf_max_command_lead" value="$(arg cbf_max_command_lead)"/>
        <param name="cbf_h_activate" value="$(arg cbf_h_activate)"/>
        <param name="cbf_max_inward_speed" value="$(arg cbf_max_inward_speed)"/>
        <param name="cbf_recovery_speed" value="$(arg cbf_recovery_speed)"/>
        <param name="cbf_recovery_depth" value="$(arg cbf_recovery_depth)"/>
        <param name="cbf_max_correction_speed" value="$(arg cbf_max_correction_speed)"/>
        <param name="cbf_recovery_max_correction_speed" value="$(arg cbf_recovery_max_correction_speed)"/>
        <param name="cbf_repair_grad_min" value="$(arg cbf_repair_grad_min)"/>
        <param name="cbf_projection_iters" value="$(arg cbf_projection_iters)"/>
        <param name="cbf_projection_relaxation" value="$(arg cbf_projection_relaxation)"/>
        <param name="cbf_tracking_feedback_mode" value="$(arg cbf_tracking_feedback_mode)"/>
        <param name="cbf_projection_metric" value="$(arg cbf_projection_metric)"/>
        <param name="cbf_task_metric_lambda" value="$(arg cbf_task_metric_lambda)"/>
        <param name="cbf_task_metric_rot_weight" value="$(arg cbf_task_metric_rot_weight)"/>
        <param name="cbf_task_metric_update_every" value="$(arg cbf_task_metric_update_every)"/>
        <param name="cbf_nullspace_clearance_gain" value="$(arg cbf_nullspace_clearance_gain)"/>
        <param name="cbf_nullspace_clearance_h_activate" value="$(arg cbf_nullspace_clearance_h_activate)"/>
        <param name="cbf_escape_enabled" value="$(arg cbf_escape_enabled)"/>
        <param name="cbf_escape_h_trigger" value="$(arg cbf_escape_h_trigger)"/>
        <param name="cbf_escape_h_release" value="$(arg cbf_escape_h_release)"/>
        <param name="cbf_escape_lift_gain" value="$(arg cbf_escape_lift_gain)"/>
        <param name="cbf_escape_max_velocity" value="$(arg cbf_escape_max_velocity)"/>
        <param name="cbf_escape_normal_gain" value="$(arg cbf_escape_normal_gain)"/>
        <param name="cbf_escape_normal_h_trigger" value="$(arg cbf_escape_normal_h_trigger)"/>
        <param name="cbf_escape_tangent_gain" value="$(arg cbf_escape_tangent_gain)"/>
        <param name="cbf_escape_gate_tau" value="$(arg cbf_escape_gate_tau)"/>
        <param name="cbf_escape_probe_enabled" value="$(arg cbf_escape_probe_enabled)"/>
        <param name="cbf_escape_probe_num_dirs" value="$(arg cbf_escape_probe_num_dirs)"/>
        <param name="cbf_escape_probe_radii" value="$(arg cbf_escape_probe_radii)"/>
        <param name="cbf_escape_probe_elevations" value="$(arg cbf_escape_probe_elevations)"/>
        <param name="cbf_escape_probe_growth_weight" value="$(arg cbf_escape_probe_growth_weight)"/>
        <param name="cbf_escape_suppress_nominal" value="$(arg cbf_escape_suppress_nominal)"/>
        <param name="cbf_escape_probe_clearance_cap" value="$(arg cbf_escape_probe_clearance_cap)"/>
        <param name="cbf_escape_probe_goal_weight" value="$(arg cbf_escape_probe_goal_weight)"/>
        <param name="cbf_escape_probe_commit_weight" value="$(arg cbf_escape_probe_commit_weight)"/>
        <param name="cbf_escape_probe_min_z" value="$(arg cbf_escape_probe_min_z)"/>
        <param name="cbf_escape_probe_ema" value="$(arg cbf_escape_probe_ema)"/>
        <param name="cbf_escape_probe_tabu_timeout" value="$(arg cbf_escape_probe_tabu_timeout)"/>
        <param name="cbf_escape_probe_tabu_min_progress" value="$(arg cbf_escape_probe_tabu_min_progress)"/>
        <param name="cbf_escape_probe_tabu_weight" value="$(arg cbf_escape_probe_tabu_weight)"/>
        <param name="cbf_escape_probe_tabu_ttl" value="$(arg cbf_escape_probe_tabu_ttl)"/>
        <param name="cbf_escape_probe_reentry_window" value="$(arg cbf_escape_probe_reentry_window)"/>
        <param name="cbf_escape_probe_resolve_timeout" value="$(arg cbf_escape_probe_resolve_timeout)"/>
        <param name="cbf_barrier_value_mode" value="$(arg cbf_barrier_value_mode)"/>
        <param name="cbf_dynamic_hdot_enabled" value="$(arg cbf_dynamic_hdot_enabled)"/>
        <param name="cbf_dynamic_hdot_tau" value="$(arg cbf_dynamic_hdot_tau)"/>
        <param name="cbf_dynamic_hdot_deadband" value="$(arg cbf_dynamic_hdot_deadband)"/>
        <param name="cbf_dynamic_hdot_max" value="$(arg cbf_dynamic_hdot_max)"/>
        <param name="barrier_alpha" value="$(arg barrier_alpha)"/>
        <param name="d_safe" value="$(arg d_safe)"/>
        <param name="cbf_integrate_from_current" value="true"/>
        <param name="use_nominal_velocity_topic" value="true"/>
        <param name="nominal_velocity_topic" value="/planner/nominal_joint_velocity"/>
        <param name="nominal_velocity_timeout" value="0.25"/>
        <param name="nominal_feedforward_gain" value="1.0"/>
        <param name="tcp_frame" value="panda_TCP"/>
        <param name="publish_diagnostics" value="true"/>
        <param name="cbf_diagnostics_decimation" value="$(arg cbf_diagnostics_decimation)"/>
        <param name="publish_viz_topics" value="$(arg launch_rviz)"/>
  </node>

  <!-- 5.2. Reflex brake layer (only with enable_cbf_reflex:=true and execute).
       Alpha-scales the intercepted CBF velocity command at ~1 kHz from the
       extrapolated per-link barrier state. Pure brake: never steers.
       exp_kappa = cbf_kappa switches the certified requirement from the
       invariance floor h_end >= h_stop to the SAME discrete exponential
       condition the QP enforces, h_end >= (1 - kappa*T) h_now: for h < 0 it
       demands certified INCREASE (attractivity half of the zeroing-CBF
       theorem, Xu et al. ADHS 2015) so a QP recovery command passes instead
       of the runPP1022 alpha = 0 freeze; h_stop stays 0 - standoff comes
       only from the certified QP margins, never a tuned floor. issf_epsilon
       mirrors the QP's disturbance bound into the reflex certificate. -->
  <node name="cbf_reflex" pkg="vision_processing" type="cbf_reflex_node.py"
        output="screen" if="$(eval arg('enable_cbf_reflex') and arg('execute'))">
        <param name="rate_hz" value="$(arg cbf_reflex_rate_hz)"/>
        <param name="h_stop" value="$(arg cbf_reflex_h_stop)"/>
        <param name="h_activate" value="$(arg cbf_h_activate)"/>
        <param name="mode" value="$(arg cbf_reflex_mode)"/>
        <param name="grad_lipschitz" value="$(arg cbf_reflex_grad_lipschitz)"/>
        <param name="exp_kappa" value="$(arg cbf_reflex_exp_kappa)"/>
        <!-- h<0 demand = recovery_slack * the QP's own recovery law (must
             match the QP's cbf_recovery_speed/_depth; see node docstring:
             kappa*|h| below zero demands more outward speed than the QP
             recovery stack delivers and vetoes the retreat). -->
        <param name="recovery_speed" value="$(arg cbf_recovery_speed)"/>
        <param name="recovery_depth" value="$(arg cbf_recovery_depth)"/>
        <param name="recovery_slack" value="0.5"/>
        <param name="issf_epsilon" value="$(arg cbf_issf_epsilon)"/>
        <param name="issf_rho" value="$(arg cbf_issf_rho)"/>
        <param name="in_velocity_topic" value="/cbf_safety/pre_reflex_command"/>
        <param name="out_velocity_topic" value="/joint_group_velocity_controller/command"/>
  </node>

  <!-- 5.5. Grasp: physically close near the cube width, weld for reliable Gazebo
       carrying, then hold the fingers at the cube width so the grasp still looks
       natural instead of visually crushing through the cube. -->
  <arg name="grasp_enabled" default="true"/>
  <node name="gripper_grasp_pp" pkg="vision_processing" type="gripper_grasp_node_pp.py"
        output="screen" if="$(arg grasp_enabled)">
        <param name="cube_model" value="red_cube"/>
        <param name="tcp_frame" value="panda_TCP"/>
        <param name="gripper_ns" value="/franka_gripper"/>
        <param name="grasp_width" value="0.04"/>
        <param name="grasp_force" value="40.0"/>
        <param name="contact_weld_finger" value="0.024"/>
        <param name="hold_after_weld" value="true"/>
        <param name="hold_width" value="0.04"/>
        <param name="open_width" value="0.08"/>
        <param name="release_z_clearance" value="0.10"/>
  </node>

  <!-- 6. RViz: visualize /vision/merged_cloud + /planner/nominal_trajectory. -->
  <node name="rviz" pkg="rviz" type="rviz"
        args="-d $(find vision_processing)/config/cbf_config.rviz"
        if="$(arg launch_rviz)"/>
</launch>
