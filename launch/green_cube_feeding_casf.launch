<launch>
  <!-- 0. Start Gazebo Simulation Environment -->
  <arg name="use_direct_group_position_controller" default="true" />
  <include file="$(find vision_processing)/launch/feeding_simulation_position_controller.launch">
    <arg name="use_direct_group_position_controller" value="$(arg use_direct_group_position_controller)" />
  </include>

  <!-- 1. General Parameters -->
  <arg name="target_prompt" default="green cube" />
  <arg name="venv_python" default="/home/flanthier/Github/src/vision_processing/venv_sam3/bin/python3" />
  <arg name="casf_model_name" default="last_fm_model_high_dim_CFM_relative_dropout.ckpt" />
  <arg name="pytorch_cuda_alloc_conf" default="expandable_segments:True" />
  <!-- waypoint_rate controls robot speed; control_rate controls interpolation/CBF update frequency. -->
  <arg name="planner_rate_hz" default="1.5" />
  <arg name="trajectory_waypoint_rate_hz" default="10.0" />
  <arg name="control_rate_hz" default="80.0" />
  <arg name="cbf_preprocess_rate_hz" default="50.0" />
  <arg name="viz_rate_hz" default="5.0" />
  <arg name="bridge_rate_hz" default="60.0" />
  <arg name="bridge_horizon_points" default="1" />
  <arg name="bridge_point_dt" default="0.02" />
  <arg name="bridge_lead_time" default="0.01" />
  <arg name="cbf_graph_points" default="100" />
  <arg name="cbf_preprocess_max_points" default="1024" />
  <arg name="cbf_candidate_filter" default="sdf" />
  <arg name="cbf_link_filter_radius" default="0.35" />
  <arg name="cbf_link_prefilter_points" default="256" />
  <arg name="cbf_sdf_candidate_max_dist" default="0.35" />
  <arg name="cbf_sdf_prune_chunk_size" default="2048" />
  <arg name="cbf_sdf_self_filter_margin" default="-0.05" />
  <arg name="cbf_sdf_prefilter_radius" default="0.35" />
  <arg name="cbf_sdf_prefilter_max_points" default="500" />
  <arg name="cbf_selection_metric" default="sdf" />
  <arg name="cbf_cluster_mode" default="topk" />
  <arg name="cbf_fork_mesh_selection_points" default="512" />
  <arg name="cbf_publish_yellow_points" default="false" />
  <arg name="cbf_selected_obstacle_hold_time" default="0.1" />
  <arg name="obstacle_pre_sample_max" default="2000" />
  <arg name="planner_cbf_max_obstacles" default="256" />
  <arg name="casf_spatial_max_obstacles" default="100" />
  <arg name="casf_barrier_memory_fraction" default="0.75" />
  <arg name="casf_barrier_min_obstacles" default="8" />
  <arg name="casf_kappa" default="50.0" />
  <arg name="casf_alpha" default="10.0" />
  <arg name="enable_casf_correction" default="false" />
  <arg name="fm_noise_seed" default="7" />
  <arg name="use_temporal_ensembler" default="false" />
  <arg name="planner_single_shot" default="false" />
  <arg name="planner_wait_for_cbf_ready" default="true" />
  <arg name="ensembler_buffer_size" default="5" />
  <arg name="ensembler_decay" default="0.5" />
  <arg name="trajectory_retime_mode" default="joint_speed" />
  <arg name="trajectory_retime_joint_speed" default="0.25" />
  <arg name="trajectory_retime_joint_weights" default="1 1 1 1 1 1 1" />
  <arg name="trajectory_retime_min_segment_fraction" default="0.02" />
  <arg name="n_pred" default="5" />
  <arg name="n_corr" default="5" />
  <arg name="alpha_corr" default="2.0" />
  <arg name="commit_distance" default="0.00" />
  <arg name="cbf_kappa" default="3.0" />
  <arg name="cbf_recovery_kappa" default="5.0" />
  <arg name="cbf_constraint_margin" default="0.001" />
  <arg name="cbf_recovery_switch_margin" default="0.000" />
  <arg name="cbf_enforce_final_constraint" default="true" />
  <arg name="cbf_integrate_from_current" default="true" />
  <arg name="cbf_command_dt" default="0.05" />
  <arg name="cbf_stateful_position_command" default="true" />
  <arg name="cbf_direct_position_mode" default="nominal_correction" />
  <arg name="cbf_position_correction_dt" default="0.08" />
  <arg name="cbf_max_command_lead" default="0.05" />
  <arg name="cbf_gradient_check_period" default="0.0" />
  <arg name="cbf_gradient_check_eps" default="0.001" />
  <arg name="barrier_alpha" default="0.001" />
  <arg name="d_safe" default="0.015" />
  <arg name="cbf_publish_safety_envelope" default="true" />
  <arg name="cbf_safety_envelope_resolution" default="40" />
  <arg name="cbf_safety_envelope_alpha" default="0.20" />
  <arg name="cbf_kp" default="5.0" />
  <arg name="max_feedback_velocity" default="0.5" />
  <arg name="cbf_filter_tau" default="0.05" />
  <arg name="cbf_velocity_filter_tau" default="0.2" />
  <arg name="cbf_use_nominal_velocity_topic" default="true" />
  <arg name="cbf_nominal_velocity_timeout" default="0.25" />
  <arg name="cbf_nominal_feedforward_gain" default="1.0" />
  <arg name="cbf_escape_enabled" default="true" />
  <arg name="cbf_escape_h_trigger" default="0.006" />
  <arg name="cbf_escape_h_release" default="0.012" />
  <arg name="cbf_escape_use_bias_corrected_h" default="true" />
  <arg name="cbf_escape_activation_cycles" default="2" />
  <arg name="cbf_escape_min_cbf_delta" default="0.02" />
  <arg name="cbf_escape_tangent_gain" default="1.5" />
  <arg name="cbf_escape_normal_gain" default="0.04" />
  <arg name="cbf_escape_normal_h_trigger" default="0.0" />
  <arg name="cbf_escape_max_velocity" default="0.2" />
  <arg name="sam_tracking_rate_hz" default="5.0" />
  <arg name="sam3_init_retry_period" default="8.0" />
  <arg name="sam3_init_backoff_after_failures" default="2" />
  <arg name="sam3_init_backoff_period" default="30.0" />
  <arg name="sam2_max_side_length" default="512" />
  <arg name="projector_max_points" default="5000" />
  <arg name="projector_max_target_points" default="2000" />
  <arg name="obstacle_sample_multiplier" default="3.0" />
  <arg name="projector_tf_timeout" default="0.01" />
  <arg name="fork_sam3_prompt" default="4 fork tips" />
  <arg name="fork_mask_dilation_px" default="7" />
  <arg name="run_3d_fork_filter_backup" default="false" />
  <arg name="persistent_voxel_size" default="0.01" />
  <!-- Freespace eviction band (m). Default ~2x voxel_size. Set very large
       (e.g. 100.0) for a baseline collision run so the static bowl is never
       evicted as the fork passes through it; the whole-body barrier then
       reaches h < 0 at true contact and contact_stop fires anywhere on the
       robot, not just the fork tip. -->
  <arg name="persistent_free_margin" default="0.02" />
  <arg name="persistent_commit_threshold" default="1" />
  <arg name="persistent_max_voxels" default="100000" />
  <arg name="persistent_robot_body_radius" default="-0.03" />
  <arg name="persistent_dilate_cloud" default="false" />
  <arg name="persistent_publish_rate_hz" default="30.0" />
  <arg name="persistent_target_exclusion_radius" default="0.005" />
  <arg name="persistent_generate_synthetic_floor" default="true" />
  <arg name="persistent_floor_sample_radius"      default="0.12" />
  <arg name="persistent_floor_grid_radius"        default="0.05" />
  <arg name="persistent_floor_grid_resolution"    default="0.005" />
  <arg name="persistent_floor_height_percentile"  default="15.0" />
  <arg name="condition_num_points" default="256" />
  <arg name="condition_target_timeout" default="5.0" />
  <arg name="condition_hold_last_target_on_loss" default="true" />
  <arg name="condition_target_hold_max_age" default="0.0" />
  <arg name="planner_hold_last_condition_on_loss" default="true" />
  <arg name="planner_condition_hold_max_age" default="0.0" />
  <arg name="max_joint_velocity" default="0.7" />
  <arg name="tcp_filter_radius" default="0.40" />
  <arg name="fork_filter_radius" default="0.3" />
  <arg name="cuda_memory_log_period" default="0.0" />
  <arg name="nominal_hold_deadband" default="0.0001" />
  <arg name="cbf_ema_alpha" default="0.15" />
  <arg name="bridge_command_timeout" default="0.5" />
  <arg name="bridge_hold_duration" default="0.25" />
  <arg name="log_sam_timing" default="false" />
  <arg name="log_projector_timing" default="false" />
  <arg name="log_projector_events" default="false" />
  <arg name="log_perception_timing" default="false" />
  <arg name="log_persistent_counts" default="false" />
  <arg name="log_cbf_events" default="false" />
  <arg name="log_cbf_command_timing" default="true" />
  <arg name="log_cbf_preprocess_breakdown" default="false" />
  <arg name="cbf_profile_sync" default="false" />
  <arg name="cbf_publish_diagnostics" default="true" />
  <arg name="fm_use_torch_compile" default="false" />
  <!-- CBF node selection: cbf_safety_node_Bernstein.py (single soft-min
       constraint, CUDA graph) or cbf_safety_node_Bernstein_multicbf.py.
       The multicbf-specific args below are ignored by the Bernstein node. -->
  <arg name="cbf_node_type" default="cbf_safety_node_Bernstein.py" />
  <arg name="cbf_solver_mode" default="fast_tangent" />
  <arg name="cbf_active_constraints" default="4" />
  <arg name="cbf_h_activate" default="0.006" />
  <arg name="cbf_max_inward_speed" default="0.20" />
  <arg name="cbf_recovery_speed" default="0.0" />
  <arg name="cbf_recovery_depth" default="0.01" />
  <arg name="cbf_max_correction_speed" default="0.35" />
  <arg name="cbf_projection_iters" default="3" />
  <arg name="cbf_projection_relaxation" default="1.0" />
  <arg name="cbf_tracking_feedback_mode" default="tangent_near" />
  <arg name="cbf_passthrough_when_inactive" default="true" />
  <!-- Baseline "sans CBF" mode: barrier and diagnostics still computed, no
       correction applied; the robot freezes at first estimated contact
       (the fork has no Gazebo collision geometry, so contact is detected
       from the perception-based clearance h_corr + d_safe <= threshold). -->
  <arg name="cbf_monitor_only" default="false" />
  <arg name="contact_stop_enabled" default="false" />
  <arg name="contact_stop_clearance" default="0.0" />
  <arg name="contact_stop_cycles" default="2" />
  <arg name="log_trajectory_timing" default="false" />
  <arg name="log_trajectory_executor_events" default="false" />
  <arg name="log_bridge_events" default="false" />
  <arg name="trajectory_use_progress_clock" default="true" />
  <arg name="trajectory_progress_lag_limit_rad" default="0.25" />
  <arg name="trajectory_cbf_hold_threshold" default="-1000.0" />
  <arg name="trajectory_anchor_mode" default="start" />
  <arg name="trajectory_command_lookahead_time" default="0.10" />
  <arg name="trajectory_velocity_out_topic" default="/planner/nominal_joint_velocity" />
  <arg name="enable_trajectory_projection" default="false" />
  <arg name="trajectory_projection_iters" default="3" />
  <arg name="trajectory_projection_margin" default="0.001" />
  <arg name="trajectory_projection_points" default="24" />
  <arg name="trajectory_projection_prefilter_radius" default="0.30" />
  <arg name="trajectory_projection_prefilter_points" default="96" />
  <arg name="trajectory_projection_check_waypoints" default="10" />
  <arg name="trajectory_projection_active_waypoints" default="4" />
  <arg name="trajectory_projection_candidate_margin" default="0.08" />
  <arg name="trajectory_projection_smooth" default="0.20" />
  <arg name="trajectory_projection_tracking" default="0.05" />
  <arg name="trajectory_projection_max_step" default="0.15" />
  <arg name="trajectory_projection_skip_first_waypoint" default="true" />
  <arg name="trajectory_projection_line_search_steps" default="2" />
  <arg name="trajectory_projection_monotonic_tolerance" default="0.0001" />
  <arg name="trajectory_projection_max_age_ms" default="350.0" />
  <arg name="log_trajectory_projection_timing" default="true" />
  
  <!-- 2. SAM3 Server is already included in feeding_simulation_position_controller.launch -->
  
  <arg name="rgb_topic" default="/camera_wrist/color/image_raw" />
  <arg name="depth_topic" default="/camera_wrist/aligned_depth_to_color/image_raw" />
  <arg name="info_topic" default="/camera_wrist/color/camera_info" />
  <arg name="launch_rviz" default="true" />

  <!-- 3. Dual SAM3+SAM2 Detector -->
  <!-- Tracks the target and publishes a 2D mask -->
  <node name="sam3_sam2" pkg="vision_processing" type="sam3_sam2_node.py" output="screen" cwd="node">
        <env name="PYTORCH_CUDA_ALLOC_CONF" value="$(arg pytorch_cuda_alloc_conf)" />
        <param name="target_prompt" value="$(arg target_prompt)" />
        <param name="publish_all_as_obstacles" value="true" />
        <param name="tracking_rate_hz" value="$(arg sam_tracking_rate_hz)" />
        <param name="sam3_init_retry_period" value="$(arg sam3_init_retry_period)" />
        <param name="sam3_init_backoff_after_failures" value="$(arg sam3_init_backoff_after_failures)" />
        <param name="sam3_init_backoff_period" value="$(arg sam3_init_backoff_period)" />
        <param name="sam2_max_side_length" value="$(arg sam2_max_side_length)" />
        <param name="log_timing" value="$(arg log_sam_timing)" />
        <param name="target_frame" value="world" />
        <param name="rgb_topic" value="$(arg rgb_topic)" />
        <param name="depth_topic" value="$(arg depth_topic)" />
        <param name="info_topic" value="$(arg info_topic)" />
  </node>

  <!-- 3.5. 3D Point Cloud Projector -->
  <!-- Converts the 2D mask + Depth into 3D Target and Obstacle point clouds -->
  <node name="point_cloud_projector" pkg="vision_processing" type="point_cloud_projector_node.py" output="screen" cwd="node">
        <param name="target_frame" value="world" />
        <param name="camera_frame" value="camera_wrist_optical_frame" />
        <param name="depth_topic" value="$(arg depth_topic)" />
        <param name="mask_topic" value="/vision/sam2_tracked_mask" />
        <param name="info_topic" value="$(arg info_topic)" />
        <param name="max_points" value="$(arg projector_max_points)" />
        <param name="max_target_points" value="$(arg projector_max_target_points)" />
        <param name="obstacle_sample_multiplier" value="$(arg obstacle_sample_multiplier)" />
        <param name="tf_timeout" value="$(arg projector_tf_timeout)" />
        <param name="log_timing" value="$(arg log_projector_timing)" />
        <param name="log_events" value="$(arg log_projector_events)" />
        <param name="run_3d_fork_filter_backup" value="$(arg run_3d_fork_filter_backup)" />
        <param name="enable_fork_sam3_mask" value="true" />
        <param name="fork_sam3_prompt" value="$(arg fork_sam3_prompt)" />
        <param name="fork_mask_dilation_px" value="$(arg fork_mask_dilation_px)" />
  </node>

  <!-- 4. Perception Processing (CropBox + ROR) -->
  <node name="perception_processor" pkg="vision_processing" type="perception_processing_node.py" output="screen" cwd="node">
        <param name="log_timing" value="$(arg log_perception_timing)" />
  </node>

  <!-- 4.5. Persistent Obstacle Map -->
  <!-- Sparse WorldCloud + GPU per-voxel freespace eviction.
       Voxels outside FOV persist indefinitely (no age-based eviction).
       Voxels inside FOV where camera sees background are evicted immediately.
       Tuning guide:
         voxel_size       — obstacle resolution (10 mm for fork-tip accuracy)
         commit_threshold — obs frames before a voxel is published (2 = fast, 3 = robust)
         free_margin      — depth band (m); camera must see this far beyond voxel to evict
                            (default 2×voxel_size = 10 mm)
         robot_body_radius — filter radius around each body link to remove self-projections -->
  <node name="persistent_cloud" pkg="vision_processing" type="persistent_cloud_node.py" output="screen" cwd="node">
        <param name="depth_topic"         value="$(arg depth_topic)" />
        <param name="info_topic"          value="$(arg info_topic)" />
        <param name="voxel_size"          value="$(arg persistent_voxel_size)" />
        <param name="free_margin"         value="$(arg persistent_free_margin)" />
        <param name="commit_threshold"    value="$(arg persistent_commit_threshold)" />
        <param name="max_voxels"          value="$(arg persistent_max_voxels)" />
        <param name="robot_body_radius"   value="$(arg persistent_robot_body_radius)" />
        <param name="dilate_published_cloud" value="$(arg persistent_dilate_cloud)" />
        <param name="publish_rate_hz"          value="$(arg persistent_publish_rate_hz)" />
        <param name="target_exclusion_radius"       value="$(arg persistent_target_exclusion_radius)" />
        <param name="generate_synthetic_floor"      value="$(arg persistent_generate_synthetic_floor)" />
        <param name="floor_sample_radius"           value="$(arg persistent_floor_sample_radius)" />
        <param name="floor_grid_radius"             value="$(arg persistent_floor_grid_radius)" />
        <param name="floor_grid_resolution"         value="$(arg persistent_floor_grid_resolution)" />
        <param name="floor_height_percentile"       value="$(arg persistent_floor_height_percentile)" />
        <param name="log_counts"          value="$(arg log_persistent_counts)" />
  </node>

  <!-- 5. Condition Merger (Target + Fork Mesh) -->
  <!-- Creates the conditioned point cloud for the Flow Matching model -->
  <node name="condition_merger" pkg="vision_processing" type="condition_pcd_from_perception.py" output="screen">
        <param name="num_points" value="$(arg condition_num_points)" />
        <param name="target_timeout" value="$(arg condition_target_timeout)" />
        <param name="hold_last_target_on_loss" value="$(arg condition_hold_last_target_on_loss)" />
        <param name="target_hold_max_age" value="$(arg condition_target_hold_max_age)" />
  </node>

  <!-- 6. CASF Generative Planner -->
  <!-- Generates nominal trajectories using Riemannian Metric Warping -->
  <node name="safe_generative_planner" pkg="vision_processing" type="casf_generative_node_PC.py" output="screen" cwd="node">
        <env name="PYTORCH_CUDA_ALLOC_CONF" value="$(arg pytorch_cuda_alloc_conf)" />
        <remap from="/planner/nominal_trajectory" to="/planner/raw_nominal_trajectory" />
        <param name="model_name" value="$(arg casf_model_name)" />
        <!-- Woodbury metric warp gains -->
        <param name="casf_kappa" value="$(arg casf_kappa)" />
        <param name="casf_alpha" value="$(arg casf_alpha)" />
        <param name="enable_casf_correction" value="$(arg enable_casf_correction)" />
        <param name="fm_noise_seed" value="$(arg fm_noise_seed)" />
        <param name="use_temporal_ensembler" value="$(arg use_temporal_ensembler)" />
        <param name="wait_for_cbf_ready" value="$(arg planner_wait_for_cbf_ready)" />
        <param name="hold_last_condition_on_loss" value="$(arg planner_hold_last_condition_on_loss)" />
        <param name="condition_hold_max_age" value="$(arg planner_condition_hold_max_age)" />
        <param name="ensembler_buffer_size" value="$(arg ensembler_buffer_size)" />
        <param name="ensembler_decay" value="$(arg ensembler_decay)" />
        <param name="log_trajectory_timing" value="$(arg log_trajectory_timing)" />
        <param name="fm_use_torch_compile" value="$(arg fm_use_torch_compile)" />
        <!-- CASF integration: n_pred controls pure FM trajectory smoothness;
             n_corr controls safety correction strength and cost. -->
        <param name="n_pred"     value="$(arg n_pred)" />
        <param name="n_corr"     value="$(arg n_corr)" />
        <param name="alpha_corr" value="$(arg alpha_corr)" />
        <param name="barrier_alpha" value="$(arg barrier_alpha)" />
        <param name="d_safe" value="$(arg d_safe)" />
        <param name="planner_rate_hz" value="$(arg planner_rate_hz)" />
        <param name="trajectory_waypoint_rate_hz" value="$(arg trajectory_waypoint_rate_hz)" />
        <param name="trajectory_retime_mode" value="$(arg trajectory_retime_mode)" />
        <param name="trajectory_retime_joint_speed" value="$(arg trajectory_retime_joint_speed)" />
        <param name="trajectory_retime_joint_weights" value="$(arg trajectory_retime_joint_weights)" />
        <param name="trajectory_retime_min_segment_fraction" value="$(arg trajectory_retime_min_segment_fraction)" />
        <param name="commit_distance" value="$(arg commit_distance)" />
        <param name="merged_cloud_contains_fork" value="true" />
        <param name="obstacle_pre_sample_max" value="$(arg obstacle_pre_sample_max)" />
        <param name="planner_cbf_max_obstacles" value="$(arg planner_cbf_max_obstacles)" />
        <param name="casf_spatial_max_obstacles" value="$(arg casf_spatial_max_obstacles)" />
        <param name="casf_barrier_memory_fraction" value="$(arg casf_barrier_memory_fraction)" />
        <param name="casf_barrier_min_obstacles" value="$(arg casf_barrier_min_obstacles)" />
        <param name="check_finite_debug" value="false" />
        <param name="single_shot" value="$(arg planner_single_shot)" />
        <param name="tcp_frame" value="panda_TCP" />
  </node>

  <!-- 6.5. SDF Trajectory Projector -->
  <!-- Reshapes the full FM joint trajectory before the time executor follows it.
       This gives the CBF a nominal path that already leaves the bowl/obstacle
       margin, instead of asking the online CBF to perform the whole bypass. -->
  <node name="sdf_trajectory_projector" pkg="vision_processing" type="sdf_trajectory_projector.py" output="screen" cwd="node">
        <env name="PYTORCH_CUDA_ALLOC_CONF" value="$(arg pytorch_cuda_alloc_conf)" />
        <param name="enabled" value="$(arg enable_trajectory_projection)" />
        <param name="input_topic" value="/planner/raw_nominal_trajectory" />
        <param name="output_topic" value="/planner/nominal_trajectory" />
        <param name="obs_topic" value="/perception/persistent_obstacles" />
        <param name="d_safe" value="$(arg d_safe)" />
        <param name="barrier_alpha" value="$(arg barrier_alpha)" />
        <param name="projection_iters" value="$(arg trajectory_projection_iters)" />
        <param name="projection_margin" value="$(arg trajectory_projection_margin)" />
        <param name="projection_max_points" value="$(arg trajectory_projection_points)" />
        <param name="prefilter_radius" value="$(arg trajectory_projection_prefilter_radius)" />
        <param name="prefilter_max_points" value="$(arg trajectory_projection_prefilter_points)" />
        <param name="check_waypoints" value="$(arg trajectory_projection_check_waypoints)" />
        <param name="active_waypoints" value="$(arg trajectory_projection_active_waypoints)" />
        <param name="sdf_candidate_margin" value="$(arg trajectory_projection_candidate_margin)" />
        <param name="smooth_relaxation" value="$(arg trajectory_projection_smooth)" />
        <param name="tracking_relaxation" value="$(arg trajectory_projection_tracking)" />
        <param name="max_joint_step_per_iter" value="$(arg trajectory_projection_max_step)" />
        <param name="max_joint_velocity" value="$(arg max_joint_velocity)" />
        <param name="skip_first_waypoint" value="$(arg trajectory_projection_skip_first_waypoint)" />
        <param name="line_search_steps" value="$(arg trajectory_projection_line_search_steps)" />
        <param name="monotonic_tolerance" value="$(arg trajectory_projection_monotonic_tolerance)" />
        <param name="projection_max_age_ms" value="$(arg trajectory_projection_max_age_ms)" />
        <param name="log_timing" value="$(arg log_trajectory_projection_timing)" />
        <param name="publish_viz" value="$(arg launch_rviz)" />
  </node>

  <!-- 7. Trajectory Executor -->
  <!-- Interpolates the CASF JointTrajectory at the control rate and feeds the CBF. -->
  <node name="trajectory_executor" pkg="vision_processing" type="trajectory_executor.py" output="screen">
        <param name="rate_hz"   value="$(arg control_rate_hz)" />
        <param name="out_topic" value="/planner/nominal_joint_command" />
        <param name="velocity_out_topic" value="$(arg trajectory_velocity_out_topic)" />
        <param name="hold_current_until_trajectory" value="true" />
        <param name="log_timing" value="$(arg log_trajectory_timing)" />
        <param name="use_progress_clock" value="$(arg trajectory_use_progress_clock)" />
        <param name="progress_lag_limit_rad" value="$(arg trajectory_progress_lag_limit_rad)" />
        <param name="cbf_hold_threshold" value="$(arg trajectory_cbf_hold_threshold)" />
        <param name="anchor_mode" value="$(arg trajectory_anchor_mode)" />
        <param name="command_lookahead_time" value="$(arg trajectory_command_lookahead_time)" />
        <param name="log_events" value="$(arg log_trajectory_executor_events)" />
  </node>

  <!-- 8. Bernstein-Basis CBF Safety Shield.
       The CBF intercepts the nominal command and publishes /planner/safe_joint_command.
       In direct mode it also commands /joint_group_position_controller/command.
       Tuning guide:
         cbf_kappa    — class-K gain: lower = softer correction (try 1.0–3.0, was 10.0)
         barrier_alpha — softmin temperature: higher = smoother gradient direction (try 0.003–0.007)
         d_safe        — minimum clearance enforced by the QP (metres) -->
  <node name="cbf_safety_Bernstein" pkg="vision_processing" type="$(arg cbf_node_type)" output="screen" cwd="node">
        <env name="PYTORCH_CUDA_ALLOC_CONF" value="$(arg pytorch_cuda_alloc_conf)" />
        <param name="enable_cbf"               value="true" />
        <param name="publish_controller_command" value="$(arg use_direct_group_position_controller)" />
        <param name="rate_hz"      value="$(arg control_rate_hz)" />
        <param name="cbf_graph_points" value="$(arg cbf_graph_points)" />
        <param name="preprocess_max_points" value="$(arg cbf_preprocess_max_points)" />
        <param name="cbf_candidate_filter" value="$(arg cbf_candidate_filter)" />
        <param name="cbf_link_filter_radius" value="$(arg cbf_link_filter_radius)" />
        <param name="cbf_link_prefilter_points" value="$(arg cbf_link_prefilter_points)" />
        <param name="cbf_sdf_candidate_max_dist" value="$(arg cbf_sdf_candidate_max_dist)" />
        <param name="cbf_sdf_prune_chunk_size" value="$(arg cbf_sdf_prune_chunk_size)" />
        <param name="cbf_sdf_self_filter_margin" value="$(arg cbf_sdf_self_filter_margin)" />
        <param name="cbf_sdf_prefilter_radius" value="$(arg cbf_sdf_prefilter_radius)" />
        <param name="cbf_sdf_prefilter_max_points" value="$(arg cbf_sdf_prefilter_max_points)" />
        <param name="cbf_selection_metric" value="$(arg cbf_selection_metric)" />
        <param name="cbf_cluster_mode" value="$(arg cbf_cluster_mode)" />
        <param name="fork_mesh_selection_points" value="$(arg cbf_fork_mesh_selection_points)" />
        <param name="publish_yellow_points" value="$(arg cbf_publish_yellow_points)" />
        <param name="selected_obstacle_hold_time" value="$(arg cbf_selected_obstacle_hold_time)" />
        <param name="cbf_kappa"    value="$(arg cbf_kappa)" />
        <param name="cbf_recovery_kappa" value="$(arg cbf_recovery_kappa)" />
        <param name="cbf_constraint_margin" value="$(arg cbf_constraint_margin)" />
        <param name="cbf_recovery_switch_margin" value="$(arg cbf_recovery_switch_margin)" />
        <param name="cbf_enforce_final_constraint" value="$(arg cbf_enforce_final_constraint)" />
        <param name="cbf_integrate_from_current" value="$(arg cbf_integrate_from_current)" />
        <param name="cbf_command_dt" value="$(arg cbf_command_dt)" />
        <param name="cbf_stateful_position_command" value="$(arg cbf_stateful_position_command)" />
        <param name="cbf_direct_position_mode" value="$(arg cbf_direct_position_mode)" />
        <param name="cbf_position_correction_dt" value="$(arg cbf_position_correction_dt)" />
        <param name="cbf_max_command_lead" value="$(arg cbf_max_command_lead)" />
        <param name="cbf_gradient_check_period" value="$(arg cbf_gradient_check_period)" />
        <param name="cbf_gradient_check_eps" value="$(arg cbf_gradient_check_eps)" />
        <param name="log_cbf_events" value="$(arg log_cbf_events)" />
        <param name="log_cbf_command_timing" value="$(arg log_cbf_command_timing)" />
        <param name="publish_diagnostics" value="$(arg cbf_publish_diagnostics)" />
        <!-- multicbf-only parameters (unread by the Bernstein node) -->
        <param name="cbf_solver_mode" value="$(arg cbf_solver_mode)" />
        <param name="cbf_active_constraints" value="$(arg cbf_active_constraints)" />
        <param name="cbf_h_activate" value="$(arg cbf_h_activate)" />
        <param name="cbf_max_inward_speed" value="$(arg cbf_max_inward_speed)" />
        <param name="cbf_recovery_speed" value="$(arg cbf_recovery_speed)" />
        <param name="cbf_recovery_depth" value="$(arg cbf_recovery_depth)" />
        <param name="cbf_max_correction_speed" value="$(arg cbf_max_correction_speed)" />
        <param name="cbf_projection_iters" value="$(arg cbf_projection_iters)" />
        <param name="cbf_projection_relaxation" value="$(arg cbf_projection_relaxation)" />
        <param name="cbf_tracking_feedback_mode" value="$(arg cbf_tracking_feedback_mode)" />
        <param name="cbf_passthrough_when_inactive" value="$(arg cbf_passthrough_when_inactive)" />
        <param name="cbf_monitor_only" value="$(arg cbf_monitor_only)" />
        <param name="contact_stop_enabled" value="$(arg contact_stop_enabled)" />
        <param name="contact_stop_clearance" value="$(arg contact_stop_clearance)" />
        <param name="contact_stop_cycles" value="$(arg contact_stop_cycles)" />
        <param name="log_trajectory_timing" value="$(arg log_trajectory_timing)" />
        <param name="barrier_alpha" value="$(arg barrier_alpha)" />
        <param name="d_safe"       value="$(arg d_safe)" />
        <param name="publish_safety_envelope" value="$(arg cbf_publish_safety_envelope)" />
        <param name="safety_envelope_resolution" value="$(arg cbf_safety_envelope_resolution)" />
        <param name="safety_envelope_alpha" value="$(arg cbf_safety_envelope_alpha)" />
        <param name="max_joint_velocity" value="$(arg max_joint_velocity)" />
        <param name="cbf_kp"                   value="$(arg cbf_kp)" />
        <param name="max_feedback_velocity"    value="$(arg max_feedback_velocity)" />
        <param name="cbf_filter_tau"           value="$(arg cbf_filter_tau)" />
        <param name="cbf_velocity_filter_tau"  value="$(arg cbf_velocity_filter_tau)" />
        <param name="use_nominal_velocity_topic" value="$(arg cbf_use_nominal_velocity_topic)" />
        <param name="nominal_velocity_topic" value="$(arg trajectory_velocity_out_topic)" />
        <param name="nominal_velocity_timeout" value="$(arg cbf_nominal_velocity_timeout)" />
        <param name="nominal_feedforward_gain" value="$(arg cbf_nominal_feedforward_gain)" />
        <param name="cbf_escape_enabled"       value="$(arg cbf_escape_enabled)" />
        <param name="cbf_escape_h_trigger"     value="$(arg cbf_escape_h_trigger)" />
        <param name="cbf_escape_h_release"     value="$(arg cbf_escape_h_release)" />
        <param name="cbf_escape_use_bias_corrected_h" value="$(arg cbf_escape_use_bias_corrected_h)" />
        <param name="cbf_escape_activation_cycles" value="$(arg cbf_escape_activation_cycles)" />
        <param name="cbf_escape_min_cbf_delta" value="$(arg cbf_escape_min_cbf_delta)" />
        <param name="cbf_escape_tangent_gain"  value="$(arg cbf_escape_tangent_gain)" />
        <param name="cbf_escape_normal_gain"   value="$(arg cbf_escape_normal_gain)" />
        <param name="cbf_escape_normal_h_trigger" value="$(arg cbf_escape_normal_h_trigger)" />
        <param name="cbf_escape_max_velocity"  value="$(arg cbf_escape_max_velocity)" />
        <param name="tcp_filter_radius" value="$(arg tcp_filter_radius)" />
        <param name="fork_filter_radius" value="$(arg fork_filter_radius)" />
        <!-- persistent_obstacles is built from cleaned_obstacles (food already excluded by SAM2)
             so the food cube never blocks approach, while outside-FOV obstacles persist. -->
        <param name="obs_topic"    value="/perception/persistent_obstacles" />
        <param name="preprocess_rate_hz" value="$(arg cbf_preprocess_rate_hz)" />
        <param name="viz_rate_hz" value="$(arg viz_rate_hz)" />
        <param name="publish_debug_topics" value="false" />
        <param name="publish_viz_topics" value="$(arg launch_rviz)" />
        <param name="profile_sync" value="$(arg cbf_profile_sync)" />
        <param name="log_cbf_preprocess_breakdown" value="$(arg log_cbf_preprocess_breakdown)" />
        <param name="cuda_memory_log_period" value="$(arg cuda_memory_log_period)" />
        <param name="nominal_hold_deadband" value="$(arg nominal_hold_deadband)" />
        <param name="cbf_ema_alpha" value="$(arg cbf_ema_alpha)" />
  </node>

  <!-- 9. Trajectory Controller Bridge.
       Used only when use_direct_group_position_controller is false.
       Converts the CBF safe Float64MultiArray commands into rolling
       JointTrajectory horizon chunks for position_joint_trajectory_controller.
       Tune horizon_points * point_dt to control lookahead. Short horizons reduce lag. -->
  <node name="trajectory_controller_bridge" pkg="vision_processing" type="trajectory_controller_bridge.py" output="screen"
        unless="$(arg use_direct_group_position_controller)">
        <param name="rate_hz"        value="$(arg bridge_rate_hz)" />
        <param name="in_topic"       value="/planner/safe_joint_command" />
        <param name="out_topic"      value="/position_joint_trajectory_controller/command" />
        <param name="horizon_points" value="$(arg bridge_horizon_points)" />
        <param name="point_dt"       value="$(arg bridge_point_dt)" />
        <param name="lead_time"      value="$(arg bridge_lead_time)" />
        <param name="command_timeout" value="$(arg bridge_command_timeout)" />
        <param name="hold_current_until_command" value="true" />
        <param name="hold_when_stale" value="true" />
        <param name="hold_duration"   value="$(arg bridge_hold_duration)" />
        <param name="log_events"      value="$(arg log_bridge_events)" />
  </node>

  <!-- 10. RViz Visualization -->
  <node name="rviz" pkg="rviz" type="rviz"
        args="-d $(find vision_processing)/config/cbf_config.rviz"
        if="$(arg launch_rviz)" />
</launch>
