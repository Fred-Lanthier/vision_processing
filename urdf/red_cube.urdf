<?xml version="1.0"?>
<!-- Red pick target cube. Matches the ManiSkill PickPlace cube: half-size 0.02 m
     (full 0.04). Dynamic + graspable (welded to panda_hand by the grasp node). -->
<robot name="red_cube">
  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.04 0.04 0.04"/>
      </geometry>
      <material name="red">
        <color rgba="0.8 0.1 0.1 1"/>
      </material>
    </visual>

    <collision>
      <geometry>
        <box size="0.04 0.04 0.04"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="0.000000000000000005"/>
      <inertia ixx="1.33e-7" ixy="0.0" ixz="0.0" iyy="1.33e-7" iyz="0.0" izz="1.33e-7"/>
    </inertial>
  </link>

  <gazebo reference="base_link">
    <material>Gazebo/Red</material>
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
  </gazebo>
</robot>
